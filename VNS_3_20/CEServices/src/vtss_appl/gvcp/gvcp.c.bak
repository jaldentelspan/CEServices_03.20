/* Global structure */
static gvcp_global_t GVCP_global;

/* Thread variables */
#define GVCP_CERT_THREAD_STACK_SIZE       16384
static cyg_handle_t GVCP_thread_handle;
static cyg_thread   GVCP_thread_block;
static char         GVCP_thread_stack[GVCP_CERT_THREAD_STACK_SIZE];


// get sockaddr, IPv4 or IPv6:

void *get_in_addr(struct sockaddr *sa)
{
	if (sa->sa_family == AF_INET) {
		return &(((struct sockaddr_in*)sa)->sin_addr);
	}

	return &(((struct sockaddr_in6*)sa)->sin6_addr);
}

/****************************************************************************
 * Module thread
 ****************************************************************************/
/* We create a new thread to do it for instead of in 'Init Modules' thread.
   That we don't need wait a long time in 'Init Modules' thread. */
static void GVCP_thread(cyg_addrword_t data)
{
#if GVCP_USING_ISGVCP_PACKAGE
int gvcp_listen_status = GVCP_LISTEN_STATUS_CLEAN;
	   while (1)
	   {
	        VTSS_OS_MSLEEP(1000);
	        T_D("GVCP thread has started and is looping..");
	        if(!gvcp_listen())
	        {
	        	T_D("gvcp_listen_status out of range.. Starting clean");

	        }
	   }
//	CPRINTF("GVCP thread has started..");
#else
    while (1) {
        VTSS_OS_MSLEEP(1000);
    }
#endif /* GVCP_USING_ISGVCP_PACKAGE */
}
int gvcp_listen()
{

	int sockfd;
	struct addrinfo hints, *servinfo, *p, *pdest, *destservinfo;
	int rv;
	int numbytes;
	struct sockaddr_storage their_addr;
	char buf[MAXBUFLEN];
	socklen_t addr_len;
	char s[INET6_ADDRSTRLEN];


	int i;
	//char * port_name;
	char * ip_name;
	char port_name[16];
	unsigned char *local_ip_name;
	unsigned int val;
	//char ip_name[16];
	//unsigned char * local_ip_name;
	gvcp_discovery_ack_t disc_pckt;
	gvcp_readreg_ack_t readreg_pckt;
	gvcp_cmd_header_t *cmd_header;


	//linked_list_node_t * root_node;
	linked_list_t readreg_list;
	init_linked_list(&readreg_list);
	init_linked_list(&MAC_TABLE);

	memset(&hints, 0, sizeof(hints));
	hints.ai_family = AF_INET; // set to AF_INET to force IPv4
	hints.ai_socktype = SOCK_DGRAM;
	hints.ai_flags = AI_PASSIVE; // use my IP

	if ((rv = getaddrinfo(NULL, GVCP_SERVERPORT, &hints, &servinfo)) != 0)
	{
		T_E(stderr, "getaddrinfo: %s\n", gai_strerror(rv));
		return -1;
	}

	// loop through all the results and bind to the first we can
	for(p = servinfo; p != NULL; p = p->ai_next) {
		if ((sockfd = socket(p->ai_family, p->ai_socktype,
				p->ai_protocol)) == -1) {
			perror("listener: socket");
			continue;
		}

		if (bind(sockfd, p->ai_addr, p->ai_addrlen) == -1) {
			close(sockfd);
			perror("listener: bind");
			continue;
		}

		break;
	}
T_D("After Bind p->ai_addr:%u", p->ai_addr);

	if (p == NULL) {
		T_E(stderr, "listener: failed to bind socket\n");
		return -2;
	}

	//freeaddrinfo(servinfo);
	addr_len = sizeof (their_addr);
	i=0;
	while(1)
	{
T_D("listener: waiting to recvfrom...\n");

		if ((numbytes = recvfrom(sockfd, buf, MAXBUFLEN-1 , 0,
			(struct sockaddr *)&their_addr, &addr_len)) == -1) {
			perror("recvfrom");
			//exit(1);
		}
T_D("Packet Recieved!!\n");


//******************************************************************************************//
//					Reply too sender on source port										 	//
//******************************************************************************************//

		ip_name = inet_ntop(their_addr.ss_family,get_in_addr((struct sockaddr *)&their_addr),s, sizeof s);
		unsigned int port_name_int = ntohs(((struct sockaddr_in*)&their_addr)->sin_port);
T_D("ip_name: %s\n",ip_name);
T_D("port_name: %d\n", port_name_int);

T_D("1\n");
		sprintf(port_name,"%u", port_name_int);
T_D("2\n");
		cmd_header = (gvcp_cmd_header_t *) buf;

T_D("3\n");

		local_ip_name =	(unsigned char *)get_in_addr((struct sockaddr *)p->ai_addr); //p->ai_addr;//

		T_D("4.0\n");		val = (*(local_ip_name)) << 24;
		T_D("4.1\n");		val |= (*(local_ip_name+1)) << 16;
		T_D("4.2\n");		val |= (*(local_ip_name+2)) << 8;
		T_D("4.3\n");		val |= (*(local_ip_name+3));

		T_D("Local IP?: %u|%02X%02X%02X%02X\n",val,
				*(local_ip_name), *(local_ip_name+1), *(local_ip_name+2), *(local_ip_name+3), *(local_ip_name+4), *(local_ip_name+5), *(local_ip_name+6));
T_D("5\n");

		if ((rv = getaddrinfo(ip_name, port_name, &hints, &destservinfo)) != 0)
		{
			T_E(stderr, "getaddrinfo: %s\n", gai_strerror(rv));
			return -3;
		}
		pdest = destservinfo;
T_D("6\n");

		if(Get_Cmd_Command(cmd_header) == DISCOVERY_CMD)
		{
T_D("Entered DISCOVERY_CMD\n");


			build_gvcp_discovery_ack_packet(&disc_pckt,	Get_Cmd_REQ_ID(cmd_header));//,parseIPV4string(host_name) );
T_D("DISCOVERY Packet has been built\n");
T_D("Sending to: %u\n", pdest->ai_addr);

			if ((numbytes = sendto(sockfd, &disc_pckt, sizeof(disc_pckt), 0, pdest->ai_addr, pdest->ai_addrlen)) == -1)
			{
				perror("talker: sendto");
				//exit(1);0
				broadcast_message(&disc_pckt, sizeof(disc_pckt));
			}
		}
		else if(Get_Cmd_Command(cmd_header) == READREG_CMD)
		{
T_D("Entered READREG_CMD\n");
T_D("Start Get_Cmd_ReadReg_Addr\n");

			Get_Cmd_ReadReg_Addr(&readreg_list, buf,Get_Cmd_Length(cmd_header));
T_D("Start Gvcp_Read_Reg_Batch\n");
			//print_list(&MAC_TABLE);
			Gvcp_Read_Reg_Batch(&readreg_list,&readreg_list);
			//print_list(&MAC_TABLE);

T_D("Start build_gvcp_readreg_ack_packet\n");

			build_gvcp_readreg_ack_packet(&readreg_pckt,&readreg_list,Get_Cmd_Length(cmd_header),Get_Cmd_REQ_ID(cmd_header));
T_D("Sending build_gvcp_readreg_ack_packet...\n");

			if ((numbytes = sendto(sockfd, readreg_pckt.data, readreg_pckt.data_size, 0,pdest->ai_addr, pdest->ai_addrlen)) == -1)
			{
				perror("talker: sendto");
				//exit(1);
			}
T_D("Freeing readreg_pckt.data\n");

			free(readreg_pckt.data);
T_D("Clearing list n DATA readreg_list\n");
			clear_list_n_data(&readreg_list);
		}
		else if(Get_Cmd_Command(cmd_header) == FORCEIP_CMD)
		{
			T_D("Entered FORCEIP_CMD\n");
					gvcp_forceip_cmd_t *forceip_cmd_pckt = (gvcp_forceip_cmd_t *) buf;
					int forceip_status;
			T_D("checking to see if it is a matching MAC\n");
			if( get_vns_mac_addr_high() == Get_Cmd_Device_MAC_High(forceip_cmd_pckt) &&
				get_vns_mac_addr_low() == Get_Cmd_Device_MAC_Low(forceip_cmd_pckt)){
T_D("Setting IP address\n");
			forceip_status = change_ip_address(1,Get_Cmd_Cur_IP(forceip_cmd_pckt),Get_Cmd_Cur_Subnet(forceip_cmd_pckt));
T_D("Build ForceIP Packet\n");
			gvcp_forceip_ack_t forceip_pckt;
			build_gvcp_forceip_ack_packet(&forceip_pckt, Get_Cmd_REQ_ID(cmd_header), forceip_status);
T_D("Sending FORCEIP ACK\n");
			if ((numbytes = sendto(sockfd, &forceip_pckt, sizeof(gvcp_forceip_ack_t), 0,pdest->ai_addr, pdest->ai_addrlen)) == -1)
			{
				perror("talker: sendto");
				//exit(1);
			}
			GVCP_LISTEN_SHUTDOWN_SEQ
			return 0;
T_D("\n");

			}
		}
T_D("7\n");

		unsigned char * ip  = (unsigned char *)get_in_addr((struct sockaddr *)&their_addr);

		T_D("listener: got packet from %s %02X%02X%02X%02X\n",ip_name,
			*(ip), *(ip+1), *(ip+2), *(ip+3));
T_D("8\n");

		T_D("Port:%d\n", ntohs(((struct sockaddr_in*)&their_addr)->sin_port));
T_D("9\n");
		T_D("listener: packet is %d bytes long\n", numbytes);

		buf[numbytes] = '\0';

T_D("10\n");

		T_D("listener: packet loop:%d\n", i);
T_D("11\n");
		T_D("KEY : %x\n", Get_Cmd_Key(cmd_header));
T_D("12\n");
		T_D("FLAG : %x\n", Get_Cmd_Flag(cmd_header));
T_D("13\n");
		T_D("CMD : %x\n", Get_Cmd_Command(cmd_header));
T_D("14\n");
		T_D("LENGTH : %x\n", Get_Cmd_Length(cmd_header));
T_D("15\n");
		T_D("REQ_ID : %x\n", Get_Cmd_REQ_ID(cmd_header));
T_D("16\n");
		T_D("size of cmd is %d\n", sizeof(gvcp_cmd_header_t));
		i++;


	}

//	close(sockfd);
//	freeaddrinfo(servinfo);
//	freeaddrinfo(destservinfo);
//	clear_list(&readreg_list);
	GVCP_LISTEN_SHUTDOWN_SEQ
	return 0;

}
void gvcp_relay_msg()
{

}

void StartGVCP()
{
	   gvcp_conf_t *conf_p;



	    /* Initialize DHCP relay configuration */
	//    conf_p = &GVCP_global.gvcp_conf;
	  //  DHCP_RELAY_default_set(conf_p);

	    /* Create semaphore for critical regions */
	//    critd_init(&GVCP_global.crit, "GVCP_global.crit", VTSS_MODULE_ID_GVCP, VTSS_TRACE_MODULE_ID, CRITD_TYPE_MUTEX);
	//    GVCP_CRIT_EXIT();


	    /* Create DHCP relay thread */
	    cyg_thread_create(THREAD_DEFAULT_PRIO,
	                      GVCP_thread,
	                      0,
	                      "GVCP",
	                      GVCP_thread_stack,
	                      sizeof(GVCP_thread_stack),
	                      &GVCP_thread_handle,
	                      &GVCP_thread_block);


	    //T_D("exit");
}






/****************************************************************************/
/*  Initialization functions                                                */
/****************************************************************************/

vtss_rc gvcp_init(vtss_init_data_t *data)
{

    switch (data->cmd) {
    case INIT_CMD_INIT:
#if (VTSS_TRACE_ENABLED)
        /* Initialize and register trace ressources */
		 VTSS_TRACE_REG_INIT(&gvcp_trace_reg, gvcp_trace_grps, GVCP_TRACE_GRP_CNT);
		 VTSS_TRACE_REGISTER(&gvcp_trace_reg);


#endif
        break;
    case INIT_CMD_START:
    	StartGVCP();
    	break;
    case INIT_CMD_MASTER_UP:
        /* Starting GVCP thread */
        cyg_thread_resume(GVCP_thread_handle);
        break;
    case INIT_CMD_CONF_DEF:
    default:
        break;
    }


    return 0;
}
