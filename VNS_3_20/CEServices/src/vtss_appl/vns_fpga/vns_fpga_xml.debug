    case CX_PARSE_CMD_PARM:
    {
        BOOL           port_list[VTSS_PORT_ARRAY_SIZE+1];
#if defined(PVLAN_SRC_MASK_ENA)
        ulong          val;
#endif /* PVLAN_SRC_MASK_ENA */
        BOOL           global;


        global = (s->isid == VTSS_ISID_GLOBAL);
        if (global) {
            s->ignored = 1;
            break;
        }

        switch (s->id) {
        case CX_TAG_VNS_FPGA_CONF_STRUCT:
