//                    first = 0;
//                    memset(conf.ports, 0, sizeof(conf.ports));
//                    pvlan_mgmt_pvlan_add(s->isid, &conf);
//                }
//            }
//#endif /* PVLAN_SRC_MASK_ENA */
            break;
        case CX_TAG_ENTRY:
 //       	printf("Entering CX_TAG_ENTRY\n");

        		{
        			int i;
        			config_transport_t conf, org_conf;
        			get_vns_fpga_master_conf_size(&conf);
        			struct_to_string_size_cal(&conf);


        			char hex_string[conf.hex_string.size];
        			conf.hex_string.pointer.c = hex_string;

        			printf("Parsing for conf_struct\n");

        			if(cx_parse_txt(s, "conf_struct", conf.hex_string.pointer.c, conf.hex_string.size) != VTSS_OK) {
        				printf("cx_parse_txt fail.  could not find conf_struct\n");
        				return VTSS_UNSPECIFIED_ERROR;
        			}

        			printf("hex_string:\n%s\n", conf.hex_string.pointer.c);
        			unsigned char byte_array[conf.data.size];
        			conf.data.pointer.uc = byte_array;
        			err = hexstring_to_struct(&conf );
        			if(0 != err) {
        				printf("cx_parse_txt fail.  could not find conf_struct\n");
        				return VTSS_UNSPECIFIED_ERROR;
        			}

#if 0
        			// TODO: just a double check... should be taken out **********************
        			for(i=0;i < conf.data.size; i++)
        				printf("%02X", conf.data.pointer.uc[i] & 0xFF);
        			printf("\n");

        			org_conf.data.size = conf.data.size;
        			unsigned char org_conf_ptr[org_conf.data.size];
        			org_conf.data.pointer.uc = org_conf_ptr;


        			if(!get_vns_fpga_master_config(&org_conf)) {
        				printf("get_vns_fpga_master_config FAILED!!!\n");
        			}

        			printf("Conf Compare, conf size %d\n", conf.data.size);
        			for(i=0; i < conf.data.size; i++) {
