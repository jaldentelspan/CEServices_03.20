        			if(!set_vns_fpga_master_config(&conf)) {
        				printf("set_vns_fpga_master_config FAILED!!!\n");
        			}
#if 0
        			printf("getting master conf...\n");
        			if(!get_vns_fpga_master_config(&org_conf)) {
        				printf("get_vns_fpga_master_config FAILED!!!\n");
        			}

        			printf("Conf Compare, conf size %d\n", conf.data.size);
        			for(i=0; i < conf.data.size; i++) {
        				printf("%d, %02X-%02X \n",i , org_conf_ptr[i], byte_array[i]);
        				if(org_conf_ptr[i] != byte_array[i])
        					printf("------------\n");
        			}
#endif

        		}


//            if (s->group == CX_TAG_PORT_TABLE && cx_parse_ports(s, port_list, 1) == VTSS_OK) {
//                s->p = s->next;
//                BOOL member[VTSS_PORT_ARRAY_SIZE], isolate;
//                if (cx_parse_bool(s, "isolate", &isolate, 1) != VTSS_OK)
//                    cx_parm_found_error(s, "isolate");
//
//                if (s->apply) {
//                    if (pvlan_mgmt_isolate_conf_get(s->isid, member) != VTSS_OK)
//                        break;
//                    (void) port_iter_init(&pit, NULL, s->isid, PORT_ITER_SORT_ORDER_IPORT, PORT_ITER_FLAGS_NORMAL);
//                    while (port_iter_getnext(&pit)) {
//                        if (port_list[pit.uport])
//                            member[pit.iport] = isolate;
//                    }
//                    pvlan_mgmt_isolate_conf_set(s->isid, member);
//                }
//            } else if (s->group == CX_TAG_VNS_FPGA_TABLE) {
//#if defined(PVLAN_SRC_MASK_ENA)
//                pvlan_mgmt_entry_t conf;
//
//                if (cx_parse_ulong(s, "pvlan_id", &val, 1, VTSS_PVLANS) != VTSS_OK)
//                    cx_parm_found_error(s, "pvlan_id");
//                else {
//                    conf.privatevid = val - 1;
//                    s->p = s->next;
//                    if (cx_parse_ports(s, port_list, 1) == VTSS_OK && s->apply) {
//                        (void) port_iter_init(&pit, NULL, s->isid, PORT_ITER_SORT_ORDER_IPORT, PORT_ITER_FLAGS_NORMAL);
//                        while (port_iter_getnext(&pit)) {
//                            conf.ports[pit.iport] = port_list[pit.uport];
//                        }
//                        pvlan_mgmt_pvlan_add(s->isid, &conf);
//                    }
//                }
//#endif /* PVLAN_SRC_MASK_ENA */
//            } else
//                s->ignored = 1;
            break;
        default:
            s->ignored = 1;
            break;
        }
        break;
    } /* CX_PARSE_CMD_PARM */
    case CX_PARSE_CMD_GLOBAL:
//       	printf("Entering CX_PARSE_CMD_GLOBAL\n");
        break;
    case CX_PARSE_CMD_SWITCH:
 //      	printf("Entering CX_PARSE_CMD_SWITCH\n");
        break;
    default:
//       	printf("Entering default\n");
        break;
    }
//   	printf("Returning vns_fpga_cx_parse_func\n");
    return s->rc;
}

static vtss_rc vns_fpga_cx_gen_func(cx_get_state_t *s)
{

#if defined(PVLAN_SRC_MASK_ENA)
    char buf[MGMT_PORT_BUF_SIZE];
#endif /* PVLAN_SRC_MASK_ENA */

    switch (s->cmd) {
    case CX_GEN_CMD_GLOBAL:

        break;
    case CX_GEN_CMD_SWITCH:
        cx_add_tag_line(s, CX_TAG_VNS_FPGA, 0);
         {

//        	sprintf(stx, "di_conf: hex value");
//          	cx_add_val_ulong_stx(s,CX_TAG_VNS_FPGA_TABLE, conf.di_config, stx );

        	cx_add_attr_start(s, CX_TAG_ENTRY);
//        	cx_add_attr_ulong(s, "version", (conf.version));
//           	cx_add_attr_ulong(s, "do_conf", (conf.do_config));
//
//         	cx_add_attr_ulong(s, "time_in", (conf.time_in_setting));
//         	cx_add_attr_ulong(s, "time_out", (conf.time_out_setting));

  			config_transport_t conf;
   			get_vns_fpga_master_conf_size(&conf);
   			printf("vns_fpga conf size %u\n", conf.data.size);

   			unsigned char conf_buf[conf.data.size];
   			conf.data.pointer.uc = conf_buf;

        	if(!get_vns_fpga_master_config(&conf)) {
				printf("get_vns_fpga_master_config FAILED!!!\n");
			}
        	int i;
  			for(i=0;i < conf.data.size; i++)
    				printf("%02X", conf.data.pointer.uc[i] & 0xFF);
    			printf("\n");

        	struct_to_string_size_cal(&conf);
  			printf("vns_fpga struct_to_string_size_cal %u\n", conf.hex_string.size);


        	char string_buf[conf.hex_string.size];
        	conf.hex_string.pointer.c = string_buf;

        	struct_to_string(&conf);
			printf("vns_fpga struct_to_string \n%s\n", conf.hex_string.pointer.c);

        	cx_add_attr_txt(s, "conf_struct", conf.hex_string.pointer.c);
        	CX_RC(cx_add_attr_end(s, CX_TAG_ENTRY));

         }
         CX_RC(cx_add_tag_line(s, CX_TAG_VNS_FPGA, 1));
        break;
    default:
        T_E("Unknown command");
        return VTSS_RC_ERROR;
        break;
    } /* End of Switch */

    return VTSS_OK;
}

/* Register the info in to the cx_module_table */
CX_MODULE_TAB_ENTRY(
    VTSS_MODULE_ID_VNS_FPGA,
	vns_fpga_cx_tag_table,
    0,
    0,
    NULL,                /* init function       */
	vns_fpga_cx_gen_func,     /* Generation fucntion */
	vns_fpga_cx_parse_func    /* parse fucntion      */
);

