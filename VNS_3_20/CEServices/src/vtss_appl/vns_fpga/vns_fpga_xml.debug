/* Tag IDs */
enum {
    /* Module tags */
    CX_TAG_VNS_FPGA,

    /* Group tags */
    CX_TAG_VNS_FPGA_CONF_STRUCT,

    /* Parameter tags */
    CX_TAG_ENTRY,

    /* Last entry */
    CX_TAG_NONE
};

/* Tag table */
static cx_tag_entry_t vns_fpga_cx_tag_table[CX_TAG_NONE + 1] =
{
    [CX_TAG_VNS_FPGA] = {
        .name  = "vns_fpga",
        .descr = "iES FPGA",
        .type = CX_TAG_TYPE_MODULE
    },

    [CX_TAG_VNS_FPGA_CONF_STRUCT] = {
        .name  = "vns_fpga_conf_struct",
        .descr = "",
        .type = CX_TAG_TYPE_GROUP
    },
    [CX_TAG_ENTRY] = {
        .name  = "entry",
        .descr = "",
        .type = CX_TAG_TYPE_PARM
    },

    /* Last entry */
    [CX_TAG_NONE] = {
        .name  = "",
        .descr = "",
        .type = CX_TAG_TYPE_NONE
    }
};

