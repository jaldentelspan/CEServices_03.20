//
// Function Segment
//   The segment allows the designer writes the local functions that will be
//   used in the command Segment and also the global functions that can be
//   shared with other C files. 
//   The content will be exactly pasted to the generated C file.
//
FUNCTION_BEGIN
static char *_oid_2_str(IN oid *name, IN int name_len, OUT char *buf)
{
    int i = 0, j = 0;

    for (i = 0; i < name_len; i++) {
        sprintf(buf + j, ".%ld", name[i]);
        j = strlen(buf);
    }
    return buf;
}

/*
    Parse raw text OID subtree string
    Return 0: successful
*/
static int _str_to_oid(IN char *str, OUT u32 *oidSubTree, INOUT u32 *oid_len)
{
    char *value_char;
    u32  num = 0;
    u32  i, mask = 0x80;

    value_char = str;

    //check if OID format .x.x.x
    if (value_char[0] != '.') {
        return 1;
    }
    for (i = 0; i < strlen(str); i++) {
        if (((value_char[i] != '.') && (value_char[i] != '*')) &&
            (value_char[i] < '0' || value_char[i] > '9')) {
            return 1;
        }
        if (value_char[i] == '*') {
            if (i == 0 || value_char[i - 1] != '.') {
                return 1;
            }
        }
        if (value_char[i] == '.') {
            if (i == strlen(str) - 1) {
                return 1;
            } else if (value_char[i + 1] == '.') {
                return 1;
            }
            num++;
            if (num > *oid_len) {
                return 1;
            }
        }
    }

    *oid_len = num;
    
    /* convert OID string (RFC1447)
       Each bit of this bit mask corresponds to the (8*i - 7)-th
       sub-identifier, and the least significant bit of the i-th
       octet of this octet string corresponding to the (8*i)-th
       sub-identifier, where i is in the range 1 through 16. */
    for (i = 0; i < num; i++) {
        if (!memcmp(value_char, ".*", 2)) {
            oidSubTree[i] = 0;
            value_char = value_char + 2;
        } else {
            sscanf(value_char++, ".%d", &oidSubTree[i]);
        }

        if (i == *oid_len - 1) {
            break; //last OID node
        }
        while (*value_char != '.') {
            value_char++;
        }

        if (mask == 1) {
            mask = 0x80;
        } else {
            mask >>= 1;
        }
    }

    return 0;
}

static void _statistics_show(IN u32 session_id, IN u32 id)
{
    vtss_stat_ctrl_entry_t  conf;
    char                    buf[80];

    memset(&conf, 0, sizeof(vtss_stat_ctrl_entry_t));
    conf.id = id;
    if ( rmon_mgmt_statistics_entry_get(&conf, FALSE) != VTSS_OK ) {
        return;
    }
    
    (void)rmon_etherStatsTable_entry_update(&conf.data_source, &conf.eth);

    ICLI_PRINTF("Statistics ID = %ld\n", conf.id);
    ICLI_PRINTF("    Data Source                   : %s\n",  _oid_2_str(conf.data_source.objid, conf.data_source.length, buf));
    ICLI_PRINTF("    etherStatsDropEvents          : %lu\n", conf.eth.drop_events   );
    ICLI_PRINTF("    etherStatsOctets              : %lu\n", conf.eth.octets        );
    ICLI_PRINTF("    etherStatsPkts                : %lu\n", conf.eth.packets       );
    ICLI_PRINTF("    etherStatsBroadcastPkts       : %lu\n", conf.eth.bcast_pkts    );
    ICLI_PRINTF("    etherStatsMulticastPkts       : %lu\n", conf.eth.mcast_pkts    );
    ICLI_PRINTF("    etherStatsCRCAlignErrors      : %lu\n", conf.eth.crc_align     );
    ICLI_PRINTF("    etherStatsUndersizePkts       : %lu\n", conf.eth.undersize     );
    ICLI_PRINTF("    etherStatsOversizePkts        : %lu\n", conf.eth.oversize      );
    ICLI_PRINTF("    etherStatsFragments           : %lu\n", conf.eth.fragments     );
    ICLI_PRINTF("    etherStatsJabbers             : %lu\n", conf.eth.jabbers       );
    ICLI_PRINTF("    etherStatsCollisions          : %lu\n", conf.eth.collisions    );
    ICLI_PRINTF("    etherStatsPkts64Octets        : %lu\n", conf.eth.pkts_64       );
    ICLI_PRINTF("    etherStatsPkts65to127Octets   : %lu\n", conf.eth.pkts_65_127   );
    ICLI_PRINTF("    etherStatsPkts128to255Octets  : %lu\n", conf.eth.pkts_128_255  );
    ICLI_PRINTF("    etherStatsPkts256to511Octets  : %lu\n", conf.eth.pkts_256_511  );
    ICLI_PRINTF("    etherStatsPkts512to1023Octets : %lu\n", conf.eth.pkts_512_1023 );
    ICLI_PRINTF("    etherStatsPkts1024to1518Octets: %lu\n", conf.eth.pkts_1024_1518);
}

static void _history_show(IN u32 session_id, IN u32 id)
{
    vtss_history_ctrl_entry_t   conf;
    vtss_history_data_entry_t   data;
    char                        buf[80];

    memset(&conf, 0, sizeof(vtss_history_ctrl_entry_t));
    conf.id = id;
    if ( rmon_mgmt_history_entry_get(&conf, FALSE) != VTSS_OK ) {
        return;
    }

    ICLI_PRINTF("History ID = %ld\n", conf.id);
    ICLI_PRINTF("    Data Source                   : %s\n",  _oid_2_str(conf.data_source.objid, conf.data_source.length, buf));
    ICLI_PRINTF("    Data Bucket Request           : %lu\n", conf.scrlr.data_requested);
    ICLI_PRINTF("    Data Bucket Granted           : %lu\n", conf.scrlr.data_granted);
    ICLI_PRINTF("    Data Interval                 : %lu\n", conf.interval);

    memset(&data, 0, sizeof(vtss_history_data_entry_t));
    while (rmon_mgmt_history_data_get(conf.id, &data, TRUE) == VTSS_OK )
    {
        ICLI_PRINTF("    EtherHistorySampleIndex = %lu\n", data.data_index);
        ICLI_PRINTF("        etherHistoryIntervalStart : %s(%lu)\n", misc_time2interval((data.start_interval) / 100), data.start_interval / 100);
        ICLI_PRINTF("        etherHistoryDropEvents    : %lu\n", data.EthData.drop_events   );
        ICLI_PRINTF("        etherHistoryOctets        : %lu\n", data.EthData.octets        );
        ICLI_PRINTF("        etherHistoryPkts          : %lu\n", data.EthData.packets       );
        ICLI_PRINTF("        etherHistoryBroadcastPkts : %lu\n", data.EthData.bcast_pkts    );
        ICLI_PRINTF("        etherHistoryMulticastPkts : %lu\n", data.EthData.mcast_pkts    );
        ICLI_PRINTF("        etherHistoryCRCAlignErrors: %lu\n", data.EthData.crc_align     );
        ICLI_PRINTF("        etherHistoryUndersizePkts : %lu\n", data.EthData.undersize     );
        ICLI_PRINTF("        etherHistoryOversizePkts  : %lu\n", data.EthData.oversize      );
        ICLI_PRINTF("        etherHistoryFragments     : %lu\n", data.EthData.fragments     );
        ICLI_PRINTF("        etherHistoryJabbers       : %lu\n", data.EthData.jabbers       );
        ICLI_PRINTF("        etherHistoryCollisions    : %lu\n", data.EthData.collisions    );
        ICLI_PRINTF("        etherHistoryUtilization   : %lu\n", data.utilization       );
    }
}

static void _alarm_show(IN u32 session_id, IN u32 id)
{
    vtss_alarm_ctrl_entry_t     conf;
    char                        buf[80];

    memset(&conf, 0, sizeof(vtss_alarm_ctrl_entry_t));
    conf.id = id;
    if (rmon_mgmt_alarm_entry_get(&conf, FALSE) != VTSS_OK) {
        return;
    }
    
    ICLI_PRINTF("Alarm ID = %ld\n", conf.id);
    ICLI_PRINTF("      Interval               : %lu\n", conf.interval);
    ICLI_PRINTF("      Variable               : %s\n",  _oid_2_str(conf.var_name.objid, conf.var_name.length, buf));
    ICLI_PRINTF("      SampleType             : %s\n",
        (SAMPLE_TYPE_ABSOLUTE == conf.sample_type ) ? "absoluteValue" :
        (SAMPLE_TYPE_DELTA == conf.sample_type ) ? "deltaValue" : "unKnown");
    ICLI_PRINTF("      Value                  : %lu\n", conf.value);
    ICLI_PRINTF("      Startup                : %s\n",
        (ALARM_RISING == conf.startup_type ) ? "risingAlarm" : ( ALARM_FALLING == conf.startup_type ) ? "fallingAlarm" :
        (ALARM_BOTH == conf.startup_type ) ? "risingOrFallingAlarm" : "unKnown");
    ICLI_PRINTF("      RisingThrld            : %ld\n", (i32)(conf.rising_threshold));
    ICLI_PRINTF("      FallingThrld           : %ld\n", (i32)(conf.falling_threshold));
    ICLI_PRINTF("      RisingEventIndex       : %lu\n", conf.rising_event_index);
    ICLI_PRINTF("      FallingEventIndex      : %lu\n", conf.falling_event_index);
}

void _event_show(IN u32 session_id, IN u32 id)
{
    vtss_event_ctrl_entry_t conf;
    vtss_event_data_entry_t data;

    memset(&conf, 0, sizeof(vtss_event_ctrl_entry_t));
    conf.id = id;
    if (rmon_mgmt_event_entry_get(&conf, FALSE) != VTSS_OK) {
        return;
    }

    ICLI_PRINTF("Event ID = %ld\n", conf.id);
    ICLI_PRINTF("      Description            : %s\n", (conf.event_description) ? conf.event_description : "");
    ICLI_PRINTF("      Type                   : %s\n", (EVENT_NONE == conf.event_type) ? "none" :
            (EVENT_LOG == conf.event_type) ? "log" : (EVENT_TRAP == conf.event_type) ? "snmptrap" :
            (EVENT_LOG_AND_TRAP == conf.event_type) ? "logandtrap" : "unKnown");
    ICLI_PRINTF("      Community              : %s\n", conf.event_community);
    ICLI_PRINTF("      LastSent               : %s\n", misc_time2interval(conf.event_last_time_sent / 100));

    memset(&data, 0, sizeof(vtss_event_data_entry_t));
    while (rmon_mgmt_event_data_get(conf.id, &data, TRUE) == VTSS_OK ) {
        ICLI_PRINTF("      Log Index                : %lu\n", data.data_index);
        ICLI_PRINTF("          Time                 : %s\n", misc_time2interval(data.log_time / 100));
        ICLI_PRINTF("          Description          : %s\n", data.log_description);
    }
}
FUNCTION_END

//
// Export Segment
//   This segment contains the API declarations of the global functions in
//   Function Segment. This will be pasted exactly to the generated H file.
//   So, others can include the H file to use the global functions.
//
EXPORT_BEGIN
EXPORT_END

HELP_SHOW_RMON = RMON statistics

//
// Command Segment
//   This segment is the implementation of the command,
//   one segment for one command.
//
CMD_BEGIN
COMMAND   = show rmon statistics [<1~65535>]
PROPERTY  = ICLI_CMD_PROP_GREP
PRIVILEGE = ICLI_PRIVILEGE_15
IF_FLAG   = 

CMD_VAR   = 
CMD_VAR   = 
CMD_VAR   = 
CMD_VAR   = id_list

HELP      = ##ICLI_HELP_SHOW
HELP      = ##HELP_SHOW_RMON
HELP      = Display the RMON statistics table
HELP      = Statistics entry list

CMD_MODE  = ICLI_CMD_MODE_EXEC

VARIABLE_BEGIN
    u32     i;
    u32     id;
VARIABLE_END

CODE_BEGIN
    if ( id_list ) {
        for ( i = 0; i < id_list->cnt; i++ ) {
            for ( id = id_list->range[i].min; id <= id_list->range[i].max; id++ ) {
                _statistics_show(session_id, id);
            }
        }
    } else {
        for ( id = 1; id <= RMON_MAX_ENTRIES; id++ ) {
            _statistics_show(session_id, id);
        }
    }
CODE_END

CMD_END

