CMD_BEGIN

IF_FLAG = 

COMMAND = show icmp [ message <0~255> ] statistics

DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = icli_ip2_stat_icmp_show
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = ICLI_CMD_PROP_GREP

CMD_MODE = ICLI_CMD_MODE_EXEC
MODE_VAR = 

RUNTIME = 

! 1: show
! 2: icmp
! 3: message
! 4: <0~255>
! 5: statistics

CMD_VAR = 
CMD_VAR = 
CMD_VAR = has_message
CMD_VAR = v_0_to_255
CMD_VAR =

HELP = ##ICLI_HELP_SHOW
HELP = Internet Control Message Protocol (ICMP)
HELP = ICMP Message Type
HELP = Type value list
HELP = ##ICLI_HELP_STATISTICS

BYWORD = 
BYWORD = 
BYWORD = <Message : option>
BYWORD = 
BYWORD = <Statistics : option>

VARIABLE_BEGIN
VARIABLE_END

CODE_BEGIN
    if (has_message) {
        vtss_ips_icmp_stat_t    icmp_msg;
        vtss_ip_type_t          version;
        u32                     imsg;
        u32                     mdx, idx, bnd;
        char                    buf[IP2_MAX_ICMP_TXT_LEN];

        if (!v_0_to_255) {
            ICLI_PRINTF("%% Invalid given type value list.\n\n");
            return ICLI_RC_ERROR;
        }

        for (mdx = 0; mdx < v_0_to_255->cnt; mdx++) {
            bnd = v_0_to_255->range[mdx].max;
            for (idx = v_0_to_255->range[mdx].min; idx <= bnd; idx++) {
                memset(&icmp_msg, 0x0, sizeof(vtss_ips_icmp_stat_t));
                version = VTSS_IP_TYPE_IPV4;
                imsg = idx;
                if ((vtss_ip2_cntr_icmp_msg_iter_get(&version, &imsg, &icmp_msg) != VTSS_OK) &&
                    vtss_ip2_stat_icmp_type_txt(buf, IP2_MAX_ICMP_TXT_LEN, VTSS_IP_TYPE_IPV4, idx)) {
                    ICLI_PRINTF("%% Failed to get ICMPv4 message %s statistics.\n\n", buf);
                } else {
                    _icli_ip2_stat_icmp_type_display(session_id, &icmp_msg);
                }
            }
        }
    } else {
        vtss_ip_type_t          icmp_ver;
        vtss_ips_icmp_stat_t    icmp_sys;

        memset(&icmp_sys, 0x0, sizeof(vtss_ips_icmp_stat_t));
        icmp_ver = VTSS_IP_TYPE_IPV4;
        if (vtss_ip2_cntr_icmp_ver_iter_get(&icmp_ver, &icmp_sys) != VTSS_OK) {
            ICLI_PRINTF("%% Failed to get ICMPv4 statistics.\n\n");
            return ICLI_RC_ERROR;
        }

        _icli_ip2_stat_icmp_syst_display(session_id, &icmp_sys);
    }
CODE_END

CMD_END

!==============================================================================

CMD_BEGIN

IF_FLAG = 

COMMAND = show icmp6 [ message <0~255> ] statistics

DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = icli_ip2_stat_icmp6_show
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = ICLI_CMD_PROP_GREP

CMD_MODE = ICLI_CMD_MODE_EXEC
MODE_VAR = 

RUNTIME = 

! 1: show
! 2: icmp6
! 3: message
! 4: <0~255>
! 5: statistics

CMD_VAR = 
CMD_VAR = 
CMD_VAR = has_message
CMD_VAR = v_0_to_255
CMD_VAR =

HELP = ##ICLI_HELP_SHOW
HELP = Internet Control Message Protocol (ICMP) for IPv6
HELP = ICMPv6 Message Type
HELP = Type value list
HELP = ##ICLI_HELP_STATISTICS

BYWORD = 
BYWORD = 
BYWORD = <Message : option>
BYWORD = 
BYWORD = <Statistics : option>

VARIABLE_BEGIN
VARIABLE_END

CODE_BEGIN
    if (has_message) {
        vtss_ips_icmp_stat_t    icmp_msg;
        vtss_ip_type_t          version;
        u32                     imsg;
        u32                     mdx, idx, bnd;
        char                    buf[IP2_MAX_ICMP_TXT_LEN];

        if (!v_0_to_255) {
            ICLI_PRINTF("%% Invalid given type value list.\n\n");
            return ICLI_RC_ERROR;
        }

        for (mdx = 0; mdx < v_0_to_255->cnt; mdx++) {
            bnd = v_0_to_255->range[mdx].max;
            for (idx = v_0_to_255->range[mdx].min; idx <= bnd; idx++) {
                memset(&icmp_msg, 0x0, sizeof(vtss_ips_icmp_stat_t));
                version = VTSS_IP_TYPE_IPV6;
                imsg = idx;
                if ((vtss_ip2_cntr_icmp_msg_iter_get(&version, &imsg, &icmp_msg) != VTSS_OK) &&
                    vtss_ip2_stat_icmp_type_txt(buf, IP2_MAX_ICMP_TXT_LEN, VTSS_IP_TYPE_IPV6, idx)) {
                    ICLI_PRINTF("%% Failed to get ICMPv6 message %s statistics.\n\n", buf);
                } else {
                    _icli_ip2_stat_icmp_type_display(session_id, &icmp_msg);
                }
            }
        }
    } else {
        vtss_ip_type_t          icmp_ver;
        vtss_ips_icmp_stat_t    icmp_sys;

        memset(&icmp_sys, 0x0, sizeof(vtss_ips_icmp_stat_t));
        icmp_ver = VTSS_IP_TYPE_IPV6;
        if (vtss_ip2_cntr_icmp_ver_iter_get(&icmp_ver, &icmp_sys) != VTSS_OK) {
            ICLI_PRINTF("%% Failed to get ICMPv6 statistics.\n\n");
            return ICLI_RC_ERROR;
        }

        _icli_ip2_stat_icmp_syst_display(session_id, &icmp_sys);
    }
CODE_END

CMD_END

!==============================================================================

CMD_BEGIN

IF_FLAG = 

COMMAND = clear ip [ vlan <vlan_list> ] statistics

DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = icli_ip2_stat_ip_clear
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = 

CMD_MODE = ICLI_CMD_MODE_EXEC
MODE_VAR = 

RUNTIME = 

! 1: clear
! 2: ip
! 3: vlan
! 4: <vlan_list>
! 5: statistics

CMD_VAR = 
CMD_VAR = 
CMD_VAR = has_vlan
CMD_VAR = v_vlan_list
CMD_VAR =

HELP = ##ICLI_HELP_CLEAR
HELP = ##ICLI_HELP_IP
HELP = ##ICLI_HELP_INTERFACE
HELP = IP interface VLAN list
HELP = ##ICLI_HELP_STATISTICS

BYWORD = 
BYWORD = 
BYWORD = <Vlan : option>
BYWORD = 
BYWORD = <Statistics : option>

VARIABLE_BEGIN
VARIABLE_END

CODE_BEGIN
    if (has_vlan) {
        u32             mdx;
        vtss_vid_t      vidx, bnd;
        vtss_if_id_t    ifidx;

        if (!v_vlan_list) {
            ICLI_PRINTF("%% Invalid given VLAN list.\n\n");
            return ICLI_RC_ERROR;
        }

        for (mdx = 0; mdx < v_vlan_list->cnt; mdx++) {
            bnd = v_vlan_list->range[mdx].max;
            for (vidx = v_vlan_list->range[mdx].min; vidx <= bnd; vidx++) {
                memset(&ifidx, 0x0, sizeof(vtss_if_id_t));
                ifidx.type = VTSS_ID_IF_TYPE_VLAN;
                ifidx.u.vlan = vidx;
                if (vtss_ip2_stat_intf_cntr_clear(VTSS_IP_TYPE_IPV4, &ifidx) != VTSS_OK) {
                    ICLI_PRINTF("%% Failed to clear IPv4 VLAN %u statistics.\n\n", vidx);
                    return ICLI_RC_ERROR;
                }
            }
        }
    } else {
        if (vtss_ip2_stat_syst_cntr_clear(VTSS_IP_TYPE_IPV4) != VTSS_OK) {
            ICLI_PRINTF("%% Failed to clear IPv4 statistics.\n\n");
            return ICLI_RC_ERROR;
        }
    }
CODE_END

CMD_END

!==============================================================================

