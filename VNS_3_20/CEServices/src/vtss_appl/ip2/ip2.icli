#define PRINTF (void)icli_session_self_printf

#define DO_VLAN(X, W)                                     \
if (rc == VTSS_RC_OK) {                                   \
    rc = (X);                                             \
    if (rc != VTSS_RC_OK) {                               \
        PRINTF("%s: Vlan=%u %s\n", W, id, error_txt(rc)); \
    }                                                     \
}

INCLUDE_END

FUNCTION_BEGIN

static
vtss_rc get_vlan_if(vtss_vid_t vid)
{
    vtss_if_param_t param;
    if (vtss_ip2_if_exists(vid)) {
        return VTSS_OK;
    }
    vtss_if_default_param(&param);
    return vtss_ip2_if_conf_set(vid, &param);
}

static void _icli_ip2_stat_ip_syst_display(i32 session_id,
                                           vtss_ips_ip_stat_t *entry)
{
    vtss_ip_stat_data_t *stat;

    if (!entry) {
        return;
    }

    stat = &entry->data;
    ICLI_PRINTF("\n\rIP Statistics Tables (ip.31->ipTrafficStats)");
    ICLI_PRINTF("\n\r  ipSystemStatsTable (ipTrafficStats.1):System-Wide IP statistics");
    ICLI_PRINTF("\n\r    ipSystemStatsEntry (ipSystemStatsTable.1)->INDEX { IPVersion:%d }",
                entry->IPVersion);
    ICLI_PRINTF("\n\ripSystemStatsIPVersion(InetVersion)        = %d", entry->IPVersion);
    ICLI_PRINTF("\n\ripSystemStatsInReceives(Counter32)         = %u", stat->InReceives);
    ICLI_PRINTF("\n\ripSystemStatsHCInReceives(Counter64)       = %llu", stat->HCInReceives);
    ICLI_PRINTF("\n\ripSystemStatsInOctets(Counter32)           = %u", stat->InOctets);
    ICLI_PRINTF("\n\ripSystemStatsHCInOctets(Counter64)         = %llu", stat->HCInOctets);
    ICLI_PRINTF("\n\ripSystemStatsInHdrErrors(Counter32)        = %u", stat->InHdrErrors);
    ICLI_PRINTF("\n\ripSystemStatsInNoRoutes(Counter32)         = %u", stat->InNoRoutes);
    ICLI_PRINTF("\n\ripSystemStatsInAddrErrors(Counter32)       = %u", stat->InAddrErrors);
    ICLI_PRINTF("\n\ripSystemStatsInUnknownProtos(Counter32)    = %u", stat->InUnknownProtos);
    ICLI_PRINTF("\n\ripSystemStatsInTruncatedPkts(Counter32)    = %u", stat->InTruncatedPkts);
    ICLI_PRINTF("\n\ripSystemStatsInForwDatagrams(Counter32)    = %u", stat->InForwDatagrams);
    ICLI_PRINTF("\n\ripSystemStatsHCInForwDatagrams(Counter64)  = %llu", stat->HCInForwDatagrams);
    ICLI_PRINTF("\n\ripSystemStatsReasmReqds(Counter32)         = %u", stat->ReasmReqds);
    ICLI_PRINTF("\n\ripSystemStatsReasmOKs(Counter32)           = %u", stat->ReasmOKs);
    ICLI_PRINTF("\n\ripSystemStatsReasmFails(Counter32)         = %u", stat->ReasmFails);
    ICLI_PRINTF("\n\ripSystemStatsInDiscards(Counter32)         = %u", stat->InDiscards);
    ICLI_PRINTF("\n\ripSystemStatsInDelivers(Counter32)         = %u", stat->InDelivers);
    ICLI_PRINTF("\n\ripSystemStatsHCInDelivers(Counter64)       = %llu", stat->HCInDelivers);
    ICLI_PRINTF("\n\ripSystemStatsOutRequests(Counter32)        = %u", stat->OutRequests);
    ICLI_PRINTF("\n\ripSystemStatsHCOutRequests(Counter64)      = %llu", stat->HCOutRequests);
    ICLI_PRINTF("\n\ripSystemStatsOutNoRoutes(Counter32)        = %u", stat->OutNoRoutes);
    ICLI_PRINTF("\n\ripSystemStatsOutForwDatagrams(Counter32)   = %u", stat->OutForwDatagrams);
    ICLI_PRINTF("\n\ripSystemStatsHCOutForwDatagrams(Counter64) = %llu", stat->HCOutForwDatagrams);
    ICLI_PRINTF("\n\ripSystemStatsOutDiscards(Counter32)        = %u", stat->OutDiscards);
    ICLI_PRINTF("\n\ripSystemStatsOutFragReqds(Counter32)       = %u", stat->OutFragReqds);
    ICLI_PRINTF("\n\ripSystemStatsOutFragOKs(Counter32)         = %u", stat->OutFragOKs);
    ICLI_PRINTF("\n\ripSystemStatsOutFragFails(Counter32)       = %u", stat->OutFragFails);
    ICLI_PRINTF("\n\ripSystemStatsOutFragCreates(Counter32)     = %u", stat->OutFragCreates);
    ICLI_PRINTF("\n\ripSystemStatsOutTransmits(Counter32)       = %u", stat->OutTransmits);
    ICLI_PRINTF("\n\ripSystemStatsHCOutTransmits(Counter64)     = %llu", stat->HCOutTransmits);
    ICLI_PRINTF("\n\ripSystemStatsOutOctets(Counter32)          = %u", stat->OutOctets);
    ICLI_PRINTF("\n\ripSystemStatsHCOutOctets(Counter64)        = %llu", stat->HCOutOctets);
    ICLI_PRINTF("\n\ripSystemStatsInMcastPkts(Counter32)        = %u", stat->InMcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsHCInMcastPkts(Counter64)      = %llu", stat->HCInMcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsInMcastOctets(Counter32)      = %u", stat->InMcastOctets);
    ICLI_PRINTF("\n\ripSystemStatsHCInMcastOctets(Counter64)    = %llu", stat->HCInMcastOctets);
    ICLI_PRINTF("\n\ripSystemStatsOutMcastPkts(Counter32)       = %u", stat->OutMcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsHCOutMcastPkts(Counter64)     = %llu", stat->HCOutMcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsOutMcastOctets(Counter32)     = %u", stat->OutMcastOctets);
    ICLI_PRINTF("\n\ripSystemStatsHCOutMcastOctets(Counter64)   = %llu", stat->HCOutMcastOctets);
    ICLI_PRINTF("\n\ripSystemStatsInBcastPkts(Counter32)        = %u", stat->InBcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsHCInBcastPkts(Counter64)      = %llu", stat->HCInBcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsOutBcastPkts(Counter32)       = %u", stat->OutBcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsHCOutBcastPkts(Counter64)     = %llu", stat->HCOutBcastPkts);
    ICLI_PRINTF("\n\ripSystemStatsDiscontinuityTime(TimeStamp)  = (%u)%usecs%uns",
                stat->DiscontinuityTime.sec_msb,
                stat->DiscontinuityTime.seconds,
                stat->DiscontinuityTime.seconds);
    ICLI_PRINTF("\n\ripSystemStatsRefreshRate(Unsigned32)       = %u\n\r", stat->RefreshRate);
}

