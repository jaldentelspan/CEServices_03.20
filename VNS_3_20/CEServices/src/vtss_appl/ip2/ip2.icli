!==============================================================================

CMD_BEGIN
IF_FLAG = defined(VTSS_SW_OPTION_L3RT)
COMMAND = ip routing

DOC_CMD_DESC    = Enable routing for IPv4 and IPv6
DOC_CMD_USAGE   = ip routing

HELP =
HELP = Enable routing for IPv4 and IPv6

PRIVILEGE = ICLI_PRIVILEGE_15

CMD_MODE = ICLI_CMD_MODE_GLOBAL_CONFIG

VARIABLE_BEGIN
    vtss_rc rc;
    vtss_ip2_global_param_t conf;
VARIABLE_END

CODE_BEGIN
    if ((rc = vtss_ip2_global_param_get(&conf)) != VTSS_OK) {
        PRINTF("Error getting configuration: %s", error_txt(rc));
        return ICLI_RC_ERROR;
    }

    conf.enable_routing = 1;
    if ((rc = vtss_ip2_global_param_set(&conf)) != VTSS_OK) {
        PRINTF("Error setting configuration: %s", error_txt(rc));
    }
CODE_END
CMD_END

!==============================================================================

CMD_BEGIN
IF_FLAG = defined(VTSS_SW_OPTION_L3RT)
COMMAND = no ip routing

DOC_CMD_DESC    = Disable routing for IPv4 and IPv6
DOC_CMD_USAGE   = ip routing

HELP =
HELP =
HELP = Disable routing for IPv4 and IPv6

PRIVILEGE = ICLI_PRIVILEGE_15

CMD_MODE = ICLI_CMD_MODE_GLOBAL_CONFIG

VARIABLE_BEGIN
    vtss_rc rc;
    vtss_ip2_global_param_t conf;
VARIABLE_END

CODE_BEGIN
    if ((rc = vtss_ip2_global_param_get(&conf)) != VTSS_OK) {
        PRINTF("Error getting configuration: %s", error_txt(rc));
        return ICLI_RC_ERROR;
    }

    conf.enable_routing = 0;
    if ((rc = vtss_ip2_global_param_set(&conf)) != VTSS_OK) {
        PRINTF("Error setting configuration: %s", error_txt(rc));
    }
CODE_END
CMD_END

!==============================================================================

CMD_BEGIN
COMMAND = ip address { { <ipv4_addr> <ipv4_netmask> } | dhcp }

DOC_CMD_DESC    = Add an ipv4 address to the interface
DOC_CMD_DEFAULT = <no-default>
DOC_CMD_USAGE   = ip address { <ipv4_addr> <ipv4_netmask> | dhcp }
DOC_CMD_EXAMPLE = ip address 10.0.0.1 255.0.0.0

NO_FORM_DOC_CMD_DESC    = 
NO_FORM_DOC_CMD_DEFAULT = 
NO_FORM_DOC_CMD_USAGE   = 
NO_FORM_DOC_CMD_EXAMPLE = 

PRIVILEGE = ICLI_PRIVILEGE_15

CMD_MODE = ICLI_CMD_MODE_INTERFACE_VLAN
MODE_VAR = vlist

CMD_VAR = 
CMD_VAR = 
CMD_VAR = v_ipv4_addr
CMD_VAR = v_ipv4_netmask
CMD_VAR = has_dhcp

HELP = IPv4 configuration
HELP = Add an ipv4 address to the interface
HELP = IPv4 address
HELP = IPv4 netmask
HELP = Use dhcp client to configure interface

VARIABLE_BEGIN
    vtss_rc rc;
    vtss_ip_conf_t ip_conf;
VARIABLE_END

CODE_BEGIN
    if (has_dhcp) {
        ip_conf.dhcpc = TRUE;

    } else {
        ip_conf.dhcpc = FALSE;
        rc = vtss_build_ipv4_network(&ip_conf.network,
                                     v_ipv4_addr, v_ipv4_netmask);
        if (rc != VTSS_RC_OK) {
            PRINTF("Could not construct a ipv4 network from the given "
                   "arguments\n");
            goto EXIT;
        }
    }

    VTSS_ICLI_RANGE_FOREACH (vlist, u32, id) {
        if (get_vlan_if(id) != VTSS_RC_OK) {
            PRINTF("Could not get interface for vlan:%u\n", id);
            continue;
        }

        if (vtss_ip2_ipv4_conf_set(id, &ip_conf) != VTSS_RC_OK) {
            PRINTF("Failed to add IPv4 address: vlan = %u\n", id);
        }
    } VTSS_ICLI_RANGE_FOREACH_END();

    EXIT:
CODE_END
CMD_END

!==============================================================================

CMD_BEGIN
COMMAND = no ip address [ { <ipv4_addr> <ipv4_netmask> } | dhcp ]

DOC_CMD_DESC    = Delete interface 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = 
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = ICLI_CMD_PROP_LOOSELY

CMD_MODE = ICLI_CMD_MODE_INTERFACE_VLAN
MODE_VAR = vlist

CMD_VAR = 
CMD_VAR = 
CMD_VAR = 
CMD_VAR = v_ipv4_addr
CMD_VAR = v_ipv4_netmask
CMD_VAR = v_dhcp

HELP = 
HELP = 
HELP = 
HELP = Address
HELP = Netmask
HELP = Use dhcp

VARIABLE_BEGIN
    vtss_rc rc = VTSS_RC_OK;
    vtss_ip_conf_t no_addr_conf = {
        .dhcpc = FALSE,
        .network = { .address = { .type = VTSS_IP_TYPE_NONE, } }
    };
    vtss_ip_network_t network = { .address = { .type = VTSS_IP_TYPE_NONE, } };
    v_ipv4_addr = 0xffffffff;
    v_ipv4_netmask = 0xffffffff;
VARIABLE_END

CODE_BEGIN
    VTSS_ICLI_RANGE_FOREACH (vlist, u32, id) {
        if (!vtss_ip2_if_exists(id)) {
            continue;
        }

        rc = VTSS_RC_OK;
        if (v_dhcp) {
            // check if we are using dhcp, and if so disable dhcp 
            vtss_ip_conf_t old;
            DO_VLAN(vtss_ip2_ipv4_conf_get(id, &old), "Get IPv4 conf");
            if (old.dhcpc) {
                DO_VLAN(vtss_ip2_ipv4_conf_set(id, &no_addr_conf), "Delete IPv4 address");
            } else {
                PRINTF("DHCP not configured on interface\n");
            }

        } else if (v_ipv4_addr != 0xffffffff) {
            // check if the given network address is configured on the
            // given interface, and if so delete it
            vtss_ip_conf_t old;
            DO_VLAN(vtss_ip2_ipv4_conf_get(id, &old), "Get IPv4 conf");
            DO_VLAN(vtss_build_ipv4_network(&network, v_ipv4_addr, v_ipv4_netmask), "Invalid params");
            if (rc == VTSS_RC_OK) {
                if (vtss_ip_net_equal(&network, &old.network)) {
                    DO_VLAN(vtss_ip2_ipv4_conf_set(id, &no_addr_conf), "Delete IPv4 address");
                } else {
                    PRINTF("Vlan=%u No such addres\n", id);
                }
            }

        } else {
            // delete all ipv4 address on the given interface
            DO_VLAN(vtss_ip2_ipv4_conf_set(id, &no_addr_conf), "Delete IPv4 address");
        }
    } VTSS_ICLI_RANGE_FOREACH_END()

CODE_END

CMD_END

!==============================================================================

CMD_BEGIN
COMMAND = ip route <ipv4_addr> <ipv4_netmask> <ipv4_addr>

DOC_CMD_DESC    = Add new IP route
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE = ICLI_CMD_MODE_GLOBAL_CONFIG

CMD_VAR = 
CMD_VAR = 
CMD_VAR = v_ipv4_addr
CMD_VAR = v_ipv4_netmask
CMD_VAR = v_ipv4_gw

BYWORD =
BYWORD =
BYWORD =
BYWORD =
BYWORD = <ipv4_gateway>

HELP = 
HELP = 
HELP = Network
HELP = Netmask
HELP = Gateway

VARIABLE_BEGIN
    vtss_rc rc;
    vtss_routing_entry_t r;
    vtss_routing_params_t params = { .owner = VTSS_ROUTING_PARAM_OWNER_STATIC_USER };
VARIABLE_END

CODE_BEGIN
    rc = vtss_build_ipv4_uc(&r, v_ipv4_addr, v_ipv4_netmask, v_ipv4_gw);

    if (rc != VTSS_RC_OK) {
        PRINTF("Could not construct a ipv4 unicast route from the given "
               "arguments\n");
        goto EXIT;
    }

    rc = vtss_ip2_route_add(&r, &params);

    if (rc != VTSS_RC_OK) {
        PRINTF("Failed to add route");
        goto EXIT;
    }

    EXIT:
CODE_END
CMD_END

!==============================================================================

CMD_BEGIN
COMMAND = no ip route <ipv4_addr> <ipv4_netmask> <ipv4_addr>

DOC_CMD_DESC    = Delete an existing IP route
DOC_CMD_DEFAULT = 
