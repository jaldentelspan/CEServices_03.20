CMD_BEGIN

IF_FLAG = 

COMMAND = show ip [ vlan <vlan_list> ] statistics [ first | walk ]

DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = icli_ip2_stat_ip_show
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = ICLI_CMD_PROP_GREP

CMD_MODE = ICLI_CMD_MODE_EXEC
MODE_VAR = 

RUNTIME = 

! 1: show
! 2: ip
! 3: vlan
! 4: <vlan_list>
! 5: statistics
! 6: first
! 7: walk

CMD_VAR = 
CMD_VAR = 
CMD_VAR = has_vlan
CMD_VAR = v_vlan_list
CMD_VAR = 
CMD_VAR = has_first
CMD_VAR = has_walk

HELP = ##ICLI_HELP_SHOW_IP
HELP = ##ICLI_HELP_IP
HELP = ##ICLI_HELP_INTERFACE
HELP = IP interface VLAN list
HELP = ##ICLI_HELP_STATISTICS
HELP = Get first IPv4 (interface) statistics
HELP = Walk IPv4 (interface) statistics

BYWORD = 
BYWORD = 
BYWORD = <Vlan : option>
BYWORD = 
BYWORD = <Statistics : option>
BYWORD = <First : option>
BYWORD = <Walk : option>

VARIABLE_BEGIN
    vtss_ips_ip_stat_t          ipstat_syst;
    vtss_if_status_ip_stat_t    ipstat_intf;
    vtss_ip_type_t              version;
    vtss_if_id_vlan_t           ifvdx;
VARIABLE_END

CODE_BEGIN
    if (has_vlan) {
        u32         mdx;
        vtss_vid_t  vidx, bnd;

        if (!v_vlan_list) {
            ICLI_PRINTF("%% Invalid given VLAN list.\n\n");
            return ICLI_RC_ERROR;
        }

        if (has_first) {
            memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
            version = VTSS_IP_TYPE_IPV4;
            ifvdx = VTSS_VID_NULL;
            if (vtss_ip2_cntr_intf_stat_iter_next(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv4 interface statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first INTF entry with GetNext(IPv4, 0)->\n");
                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }

            version = VTSS_IP_TYPE_IPV4;
            ifvdx = VTSS_VID_NULL;
            if (vtss_ip2_cntr_intf_stat_iter_first(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv4 interface statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first INTF entry with GetFirst(IPv4, X)->\n");
                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }
        } else if (has_walk) {
            ICLI_PRINTF("\n\rWalk INTF table with GetNext(NULL, 0)->\n");
            memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
            version = VTSS_IP_TYPE_NONE;
            ifvdx = VTSS_VID_NULL;
            while (vtss_ip2_cntr_intf_stat_iter_next(&version, &ifvdx, &ipstat_intf) == VTSS_OK) {
                version = ipstat_intf.IPVersion;
                ifvdx = ipstat_intf.IfIndex.u.vlan;
                if (ipstat_intf.IPVersion != VTSS_IP_TYPE_IPV4) {
                    ICLI_PRINTF("\n\rCAN-Stop walking INTF table with version %d\n", ipstat_intf.IPVersion);
//                    break;
                }

                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }
        } else {
            for (mdx = 0; mdx < v_vlan_list->cnt; mdx++) {
                bnd = v_vlan_list->range[mdx].max;
                for (vidx = v_vlan_list->range[mdx].min; vidx <= bnd; vidx++) {
                    memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
                    version = VTSS_IP_TYPE_IPV4;
                    ifvdx = vidx;
                    if (vtss_ip2_cntr_intf_stat_iter_get(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                        ICLI_PRINTF("%% Failed to get IPv4 VLAN %u statistics.\n\n", vidx);
                        continue;
                    }

                    _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
                }
            }
        }
    } else {
        if (has_first) {
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_NONE;
            if (vtss_ip2_cntr_syst_stat_iter_next(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv4 statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first SYST entry with GetNext(NULL, 0)->\n");
                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }

            version = VTSS_IP_TYPE_IPV4;
            if (vtss_ip2_cntr_syst_stat_iter_first(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv4 statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first SYST entry with GetFirst(IPV4, X)->\n");
                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }
        } else if (has_walk) {
            ICLI_PRINTF("\n\rWalk SYST table with GetNext(NULL, 0)->\n");
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_NONE;
            while (vtss_ip2_cntr_syst_stat_iter_next(&version, &ipstat_syst) == VTSS_OK) {
                version = ipstat_syst.IPVersion;
                if (ipstat_syst.IPVersion != VTSS_IP_TYPE_IPV4) {
                    ICLI_PRINTF("\n\rCAN-Stop walking SYST table with version %d\n", ipstat_syst.IPVersion);
//                    break;
                }

                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }
        } else {
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_IPV4;
            if (vtss_ip2_cntr_syst_stat_iter_get(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get IPv4 statistics.\n\n");
                return ICLI_RC_ERROR;
            }

            _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
        }
    }
CODE_END

CMD_END

!==============================================================================

CMD_BEGIN

IF_FLAG = 

COMMAND = show ipv6 [ vlan <vlan_list> ] statistics [ first | walk ]

DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 

FUNC_NAME = icli_ip2_stat_ipv6_show
FUNC_REUSE = 

PRIVILEGE = ICLI_PRIVILEGE_15
PROPERTY  = ICLI_CMD_PROP_GREP

CMD_MODE = ICLI_CMD_MODE_EXEC
MODE_VAR = 

RUNTIME = 

! 1: show
! 2: ipv6
! 3: vlan
! 4: <vlan_list>
! 5: statistics
! 6: first
! 7: walk

CMD_VAR = 
CMD_VAR = 
CMD_VAR = has_vlan
CMD_VAR = v_vlan_list
CMD_VAR = 
CMD_VAR = has_first
CMD_VAR = has_walk

HELP = ##ICLI_HELP_SHOW_IP
HELP = ##ICLI_HELP_IPV6
HELP = ##ICLI_HELP_INTERFACE
HELP = IPv6 interface VLAN list
HELP = ##ICLI_HELP_STATISTICS
HELP = Get first IP (interface) statistics
HELP = Walk IP (interface) statistics

BYWORD = 
BYWORD = 
BYWORD = <Vlan : option>
BYWORD = 
BYWORD = <Statistics : option>
BYWORD = <First : option>
BYWORD = <Walk : option>

VARIABLE_BEGIN
    vtss_ips_ip_stat_t          ipstat_syst;
    vtss_if_status_ip_stat_t    ipstat_intf;
    vtss_ip_type_t              version;
    vtss_if_id_vlan_t           ifvdx;
VARIABLE_END

CODE_BEGIN
    if (has_vlan) {
        u32         mdx;
        vtss_vid_t  vidx, bnd;

        if (!v_vlan_list) {
            ICLI_PRINTF("%% Invalid given VLAN list.\n\n");
            return ICLI_RC_ERROR;
        }

        if (has_first) {
            memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
            version = VTSS_IP_TYPE_IPV6;
            ifvdx = VTSS_VID_NULL;
            if (vtss_ip2_cntr_intf_stat_iter_next(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv6 interface statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first INTF entry with GetNext(IPv6, 0)->\n");
                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }

            version = VTSS_IP_TYPE_IPV6;
            ifvdx = VTSS_VID_NULL;
            if (vtss_ip2_cntr_intf_stat_iter_first(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv6 interface statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first INTF entry with GetFirst(IPv6, X)->\n");
                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }
        } else if (has_walk) {
            ICLI_PRINTF("\n\rWalk INTF table with GetNext(IPv6, 0)->\n");
            memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
            version = VTSS_IP_TYPE_IPV6;
            ifvdx = VTSS_VID_NULL;
            while (vtss_ip2_cntr_intf_stat_iter_next(&version, &ifvdx, &ipstat_intf) == VTSS_OK) {
                version = ipstat_intf.IPVersion;
                ifvdx = ipstat_intf.IfIndex.u.vlan;
                if (ipstat_intf.IPVersion != VTSS_IP_TYPE_IPV6) {
                    ICLI_PRINTF("\n\rMUST-Stop walking INTF table with version %d\n", ipstat_intf.IPVersion);
                    break;
                }

                _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
            }
        } else {
            for (mdx = 0; mdx < v_vlan_list->cnt; mdx++) {
                bnd = v_vlan_list->range[mdx].max;
                for (vidx = v_vlan_list->range[mdx].min; vidx <= bnd; vidx++) {
                    memset(&ipstat_intf, 0x0, sizeof(vtss_if_status_ip_stat_t));
                    version = VTSS_IP_TYPE_IPV6;
                    ipstat_intf.IfIndex.type = VTSS_ID_IF_TYPE_VLAN;
                    ifvdx = vidx;
                    if (vtss_ip2_cntr_intf_stat_iter_get(&version, &ifvdx, &ipstat_intf) != VTSS_OK) {
                        ICLI_PRINTF("%% Failed to get IPv6 VLAN %u statistics.\n\n", vidx);
                        continue;
                    }

                    _icli_ip2_stat_ip_intf_display(session_id, &ipstat_intf);
                }
            }
        }
    } else {
        if (has_first) {
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_IPV4;
            if (vtss_ip2_cntr_syst_stat_iter_next(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv6 statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first SYST entry with GetNext(IPV4, 0)->\n");
                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }

            version = VTSS_IP_TYPE_IPV6;
            if (vtss_ip2_cntr_syst_stat_iter_first(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get first IPv6 statistics.\n\n");
            } else {
                ICLI_PRINTF("\n\rGet first SYST entry with GetFirst(IPV6, X)->\n");
                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }
        } else if (has_walk) {
            ICLI_PRINTF("\n\rWalk SYST table with GetNext(NULL, 0)->\n");
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_NONE;
            while (vtss_ip2_cntr_syst_stat_iter_next(&version, &ipstat_syst) == VTSS_OK) {
                version = ipstat_syst.IPVersion;
                if (ipstat_syst.IPVersion != VTSS_IP_TYPE_IPV6) {
                    ICLI_PRINTF("\n\rCAN-Skip walking SYST table with version %d\n", ipstat_syst.IPVersion);
//                    continue;
                }

                _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
            }
        } else {
            memset(&ipstat_syst, 0x0, sizeof(vtss_ips_ip_stat_t));
            version = VTSS_IP_TYPE_IPV6;
            if (vtss_ip2_cntr_syst_stat_iter_get(&version, &ipstat_syst) != VTSS_OK) {
                ICLI_PRINTF("%% Failed to get IPv6 statistics.\n\n");
                return ICLI_RC_ERROR;
            }

            _icli_ip2_stat_ip_syst_display(session_id, &ipstat_syst);
        }
    }
CODE_END

CMD_END

