static void _icli_ip2_stat_icmp_syst_display(i32 session_id,
                                             vtss_ips_icmp_stat_t *entry)
{
    vtss_icmp_stat_data_t   *stat;

    if (!entry) {
        return;
    }

    stat = &entry->data;
    ICLI_PRINTF("\n\rICMP Statistics Tables (icmp.29->icmpStatsTable)");
    ICLI_PRINTF("\n\r  icmpStatsTable (icmp.29->icmpStatsTable):Per-Version ICMP statistics");
    ICLI_PRINTF("\n\r    icmpStatsEntry (icmpStatsTable.1)->INDEX { IPVersion:%d }",
                entry->IPVersion);
    ICLI_PRINTF("\n\ricmpStatsIPVersion(InetVersion)    = %d",
                entry->IPVersion);
    ICLI_PRINTF("\n\ricmpStatsInMsgs(Counter32)         = %u",
                stat->InMsgs);
    ICLI_PRINTF("\n\ricmpStatsInErrors(Counter32)       = %u",
                stat->InErrors);
    ICLI_PRINTF("\n\ricmpStatsOutMsgs(Counter32)        = %u",
                stat->OutMsgs);
    ICLI_PRINTF("\n\ricmpStatsOutErrors(Counter32)      = %u\n\r",
                stat->OutErrors);
}

static void _icli_ip2_stat_icmp_type_display(i32 session_id,
                                             vtss_ips_icmp_stat_t *entry)
{
    vtss_icmp_stat_data_t   *stat;
    char                    buf[IP2_MAX_ICMP_TXT_LEN];

    if (!entry) {
        return;
    }

    stat = &entry->data;
    ICLI_PRINTF("\n\rICMP Message Statistics Tables (icmp.30->icmpMsgStatsTable)");
    ICLI_PRINTF("\n\r  icmpMsgStatsTable (ipTrafficStats.3):Per-Version Per-ICMP-Type statistics");
    ICLI_PRINTF("\n\r    icmpMsgStatsEntry (icmpMsgStatsTable.1)->INDEX { IPVersion:%d, Type:%u }",
                entry->IPVersion,
                entry->Type);
    ICLI_PRINTF("\n\ricmpMsgStatsIPVersion(InetVersion) = %d",
                entry->IPVersion);
    if (vtss_ip2_stat_icmp_type_txt(buf, IP2_MAX_ICMP_TXT_LEN, entry->IPVersion, entry->Type)) {
        ICLI_PRINTF("\n\ricmpMsgStatsType(Integer32)        = Type-%u:%s",
                    entry->Type,
                    buf);
    }
    ICLI_PRINTF("\n\ricmpMsgStatsInPkts(Counter32)      = %u",
                stat->InMsgs);
    ICLI_PRINTF("\n\ricmpMsgStatsOutPkts(Counter32)     = %u\n\r",
                stat->OutMsgs);
}
FUNCTION_END

