PRIVILEGE = ICLI_PRIVILEGE_15
CMD_MODE = ICLI_CMD_MODE_GLOBAL_CONFIG

CMD_VAR = 
CMD_VAR = 
CMD_VAR = 
CMD_VAR = v_ipv4_addr
CMD_VAR = v_ipv4_netmask
CMD_VAR = v_ipv4_gw

BYWORD =
BYWORD =
BYWORD =
BYWORD =
BYWORD =
BYWORD = <ipv4_gateway>

HELP = 
HELP = 
HELP = 
HELP = Network
HELP = Netmask
HELP = Gateway

VARIABLE_BEGIN
    vtss_rc rc;
    vtss_routing_entry_t r;
    vtss_routing_params_t params = { .owner = VTSS_ROUTING_PARAM_OWNER_STATIC_USER };
VARIABLE_END

CODE_BEGIN
    rc = vtss_build_ipv4_uc(&r, v_ipv4_addr, v_ipv4_netmask, v_ipv4_gw);

    if (rc != VTSS_RC_OK) {
        PRINTF("Could not construct a ipv4 unicast route from the given "
               "arguments\n");
        goto EXIT;
    }

    rc = vtss_ip2_route_del(&r, &params);

    if (rc != VTSS_RC_OK) {
        PRINTF("Failed to add route");
        goto EXIT;
    }

    EXIT:
CODE_END
CMD_END

