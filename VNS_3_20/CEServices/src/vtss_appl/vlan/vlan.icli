    /* Default Frame type is all */
    vport_conf.frame_type = VTSS_VLAN_FRAME_ALL;
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 1, 0, 0, 0);
NO_FORM_CODE_END
CMD_END

CMD_BEGIN
COMMAND         = switchport hybrid egress-tag {none | all [except-native]}
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_egr_tag_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set hybrid characteristics of the interface
   HELP = Egress VLAN tagging configuration
   HELP = No egress tagging
   HELP = Tag all frames
   HELP = Tag all frames except frames classified to native VLAN of the hybrid port

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_none
   CMD_VAR   = has_all
   CMD_VAR   = has_except_native

VARIABLE_BEGIN
   vlan_port_conf_t      vport_conf;
VARIABLE_END

CODE_BEGIN
    memset(&vport_conf, 0, sizeof(vport_conf));
    if (has_none) {
        vport_conf.tx_tag_type = VLAN_TX_TAG_TYPE_UNTAG_ALL;
    } else if (has_all) {
        if (has_except_native) {
            vport_conf.tx_tag_type = VLAN_TX_TAG_TYPE_UNTAG_THIS;
        } else {
            vport_conf.tx_tag_type = VLAN_TX_TAG_TYPE_TAG_ALL;
        }
    } else {
        ICLI_PRINTF("Invalid option\n");
        return FALSE;
    }
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 0, 0, 0, 1);
CODE_END

NO_FORM_VARIABLE_BEGIN
   vlan_port_conf_t      vport_conf;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(has_none);
    VLAN_UNUSED_PARAM(has_all);
    VLAN_UNUSED_PARAM(has_except_native);
    memset(&vport_conf, 0, sizeof(vport_conf));
    vport_conf.tx_tag_type = VLAN_TX_TAG_TYPE_UNTAG_THIS;
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 0, 0, 0, 1);
NO_FORM_CODE_END
CMD_END

