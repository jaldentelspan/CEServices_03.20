CMD_BEGIN
COMMAND         = switchport trunk allowed vlan {all | none | [add | remove | except] <vlan_list>}
# /* ---------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_trunk_allowed_vlans_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set trunking characteristics of the interface
   HELP = Set allowed VLAN characteristics when interface is in trunking mode
   HELP = Set allowed VLANs when interface is in trunking mode
   HELP = all VLANs
   HELP = no VLANs
   HELP = add VLANs to the current list
   HELP = remove VLANs from the current list
   HELP = all VLANs except the following
   HELP = VLAN IDs of the allowed VLANs when this port is in trunking mode

   CMD_VAR   =
   CMD_VAR   = 
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_all
   CMD_VAR   = has_none
   CMD_VAR   = has_add
   CMD_VAR   = has_remove
   CMD_VAR   = has_except
   CMD_VAR   = v_vlan_list

VARIABLE_BEGIN
   u32                   range_idx, cnt_idx, idx, temp;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
   vtss_vid_t            vidx;
   u8                    vid_bit_mask[VLAN_BIT_MASK_LEN], vid_except_mask[VLAN_BIT_MASK_LEN];
VARIABLE_END

CODE_BEGIN
    memset(vid_except_mask, 0, sizeof(vid_except_mask));
    memset(vid_bit_mask, 0, sizeof(vid_bit_mask));
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            if (has_all) {
                memset(vid_bit_mask, 0xFF, VLAN_BIT_MASK_LEN); /* This sets all bits */
            } else if (has_none) {
                memset(vid_bit_mask, 0x0, VLAN_BIT_MASK_LEN); /* This clears all bits */
            } else {
                if (has_add || has_remove || has_except) {
                    if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, 
                                    VLAN_PORT_MODE_TRUNK)) != VTSS_RC_OK) {
                        T_D("vlan_mgmt_port_allowed_vlans_get failed");
                        return ICLI_RC_ERROR;
                    }
                } else { /* Overwrite */
                    memset(vid_bit_mask, 0x0, VLAN_BIT_MASK_LEN); /* This clears all bits */
                }
                for (idx = 0; idx < v_vlan_list->cnt; idx++) {
                    for (vidx = v_vlan_list->range[idx].min; vidx <= (v_vlan_list->range[idx].max); vidx++) {
                        if (has_add) {
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, vidx);
                        } else if (has_remove) {
                            VLAN_CLR_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, (u32)vidx);
                        } else if (has_except) {
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_except_mask, vidx);
                        } else { /* Overwrite */
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, vidx);
                        } /* else of if (has_add) */
                    } /* for (vidx = v_vlan_list->range[idx].min; vidx <= (v_vlan_list->range[idx].max); vidx++) */
                } /* for (idx = 0; idx < v_vlan_list->cnt; idx++) */
            } /* else of if (has_all) */
            if (has_except) {
                for (temp = 0; temp < VLAN_BIT_MASK_LEN; temp++) {
                    /* Inverting vid_except_mask gives the vid mask */
                    vid_bit_mask[temp] = ~vid_except_mask[temp];
                } /* for (temp = 0; temp < VLAN_BIT_MASK_LEN; temp++) */
            } /* if (has_except) */
            if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, 
                            VLAN_PORT_MODE_TRUNK)) != VTSS_RC_OK) {
                T_D("vlan_mgmt_port_allowed_vlans_set failed");
                return ICLI_RC_ERROR;
            } /* if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask)) != VTSS_RC_OK) */
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
CODE_END

NO_FORM_VARIABLE_BEGIN
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
   u8                    vid_bit_mask[VLAN_BIT_MASK_LEN];
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(has_all);
    VLAN_UNUSED_PARAM(has_none);
    VLAN_UNUSED_PARAM(has_add);
    VLAN_UNUSED_PARAM(has_remove);
    VLAN_UNUSED_PARAM(has_except);
    VLAN_UNUSED_PARAM(v_vlan_list);
    memset(vid_bit_mask, 0, sizeof(vid_bit_mask));
    /* no switchport trunk allowed vlan - resets the list to the default list, which allows all VLANs */
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            memset(vid_bit_mask, 0xFF, VLAN_BIT_MASK_LEN); /* This sets all bits */
            if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, VLAN_PORT_MODE_TRUNK)) 
                    != VTSS_RC_OK) {
                T_D("vlan_mgmt_port_allowed_vlans_set failed");
                return ICLI_RC_ERROR;
            } /* if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask)) != VTSS_RC_OK) */
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
NO_FORM_CODE_END
CMD_END

CMD_BEGIN
COMMAND         = switchport hybrid allowed vlan {all | none | [add | remove | except] <vlan_list>}
# /* ---------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_hybrid_allowed_vlans_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set trunking characteristics of the interface
   HELP = Set hybrid characteristics of the interface
   HELP = Set allowed VLAN characteristics when interface is in trunking mode
   HELP = Set allowed VLANs when interface is in trunking mode
   HELP = all VLANs
   HELP = no VLANs
   HELP = add VLANs to the current list
   HELP = remove VLANs from the current list
   HELP = all VLANs except the following
   HELP = VLAN IDs of the allowed VLANs when this port is in trunking mode

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_all
   CMD_VAR   = has_none
   CMD_VAR   = has_add
   CMD_VAR   = has_remove
   CMD_VAR   = has_except
   CMD_VAR   = v_vlan_list

VARIABLE_BEGIN
   u32                   range_idx, cnt_idx, idx, temp;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
   vtss_vid_t            vidx;
   u8                    vid_bit_mask[VLAN_BIT_MASK_LEN], vid_except_mask[VLAN_BIT_MASK_LEN];
VARIABLE_END

CODE_BEGIN
    memset(vid_except_mask, 0, sizeof(vid_except_mask));
    memset(vid_bit_mask, 0, sizeof(vid_bit_mask));
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            if (has_all) {
                memset(vid_bit_mask, 0xFF, VLAN_BIT_MASK_LEN); /* This sets all bits */
            } else if (has_none) {
                memset(vid_bit_mask, 0x0, VLAN_BIT_MASK_LEN); /* This clears all bits */
            } else {
                if (has_add || has_remove || has_except) {
                    if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, 
                                    VLAN_PORT_MODE_HYBRID)) != VTSS_RC_OK) {
                        T_D("vlan_mgmt_port_allowed_vlans_get failed");
                        return ICLI_RC_ERROR;
                    }
                } else { /* Overwrite */
                    memset(vid_bit_mask, 0x0, VLAN_BIT_MASK_LEN); /* This clears all bits */
                }
                for (idx = 0; idx < v_vlan_list->cnt; idx++) {
                    for (vidx = v_vlan_list->range[idx].min; vidx <= (v_vlan_list->range[idx].max); vidx++) {
                        if (has_add) {
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, vidx);
                        } else if (has_remove) {
                            VLAN_CLR_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, (u32)vidx);
                        } else if (has_except) {
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_except_mask, vidx);
                        } else { /* Overwrite */
                            VLAN_SET_VLAN_BIT_IN_VLAN_MASK(vid_bit_mask, vidx);
                        } /* else of if (has_add) */
                    } /* for (vidx = v_vlan_list->range[idx].min; vidx <= (v_vlan_list->range[idx].max); vidx++) */
                } /* for (idx = 0; idx < v_vlan_list->cnt; idx++) */
            } /* else of if (has_all) */
            if (has_except) {
                for (temp = 0; temp < VLAN_BIT_MASK_LEN; temp++) {
                    /* Inverting vid_except_mask gives the vid mask */
                    vid_bit_mask[temp] = ~vid_except_mask[temp];
                } /* for (temp = 0; temp < VLAN_BIT_MASK_LEN; temp++) */
            } /* if (has_except) */
            if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, 
                            VLAN_PORT_MODE_HYBRID)) != VTSS_RC_OK) {
                T_D("vlan_mgmt_port_allowed_vlans_set failed");
                return ICLI_RC_ERROR;
            } /* if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask)) != VTSS_RC_OK) */
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
CODE_END

NO_FORM_VARIABLE_BEGIN
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
   u8                    vid_bit_mask[VLAN_BIT_MASK_LEN];
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(has_all);
    VLAN_UNUSED_PARAM(has_none);
    VLAN_UNUSED_PARAM(has_add);
    VLAN_UNUSED_PARAM(has_remove);
    VLAN_UNUSED_PARAM(has_except);
    VLAN_UNUSED_PARAM(v_vlan_list);
    memset(vid_bit_mask, 0, sizeof(vid_bit_mask));
    /* no switchport trunk allowed vlan - resets the list to the default list, which allows all VLANs */
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            memset(vid_bit_mask, 0x0, VLAN_BIT_MASK_LEN); /* This clears all bits */
            if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask, VLAN_PORT_MODE_TRUNK)) 
                    != VTSS_RC_OK) {
                T_D("vlan_mgmt_port_allowed_vlans_set failed");
                return ICLI_RC_ERROR;
            } /* if ((vlan_mgmt_port_allowed_vlans_set(topo_usid2isid(usid), uport2iport(uport), vid_bit_mask)) != VTSS_RC_OK) */
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
NO_FORM_CODE_END
CMD_END

