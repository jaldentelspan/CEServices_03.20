CMD_BEGIN
COMMAND         = switchport hybrid native vlan {<vlan_id> | none}
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = Use the switchport native vlan command to configure a port to a VLAN. Valid VLAN IDs are 1 to 4095.
DOC_CMD_DEFAULT = The no form of the native vlan command resets the native mode VLAN to the appropriate default VLAN.
DOC_CMD_USAGE   = This command configures the pvid of a trunk port.
DOC_CMD_EXAMPLE = This example shows to configure a PVID of a trunk port. 
DOC_CMD_EXAMPLE = Switch(config-if)#switchport trunk native vlan 7
DOC_CMD_EXAMPLE = You can verify your settings by entering the show vlan privileged EXEC command.
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_hybrid_pvid_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set trunking characteristics of the interface
   HELP = Set hybrid characteristics of the interface
   HELP = Set native VLAN
   HELP = Set native VLAN when interface is in trunking or hybrid mode
   HELP = VLAN ID of the native VLAN when this port is in trunking or hybrid mode
   HELP = PVID is none

   CMD_VAR   =
   CMD_VAR   = 
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = in_vid
   CMD_VAR   = has_none

VARIABLE_BEGIN
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
VARIABLE_END

CODE_BEGIN
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            if (has_none) {
                if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), 0, VLAN_PORT_MODE_HYBRID))  
                    != VTSS_RC_OK) {
                    T_D("vlan_mgmt_port_native_vlan_set failed");
                } /* if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), in_vid))  != VTSS_RC_OK) */
            } else {
                if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), in_vid, VLAN_PORT_MODE_HYBRID))  
                    != VTSS_RC_OK) {
                    T_D("vlan_mgmt_port_native_vlan_set failed");
                } /* if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), in_vid))  != VTSS_RC_OK) */
            }
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
CODE_END

NO_FORM_VARIABLE_BEGIN
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(in_vid);
    VLAN_UNUSED_PARAM(has_none);
    for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
        usid = mode_port_list->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
            if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), VLAN_TAG_DEFAULT, VLAN_PORT_MODE_HYBRID))  
                    != VTSS_RC_OK) {
                T_D("vlan_mgmt_port_native_vlan_set failed");
            } /* if ((vlan_mgmt_port_native_vlan_set(topo_usid2isid(usid), uport2iport(uport), in_vid))  != VTSS_RC_OK) */
        } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
NO_FORM_CODE_END

CMD_END

CMD_BEGIN
COMMAND         = switchport hybrid port-type { unaware | c-port | s-port | s-custom-port }
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = 
DOC_CMD_DEFAULT = 
DOC_CMD_USAGE   = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
DOC_CMD_EXAMPLE = 
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_hybrid_port_type_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set hybrid characteristics of the interface
   HELP = Set port type
   HELP = Port in not aware of VLAN tags.
   HELP = Customer port
   HELP = Provider port
   HELP = Custom Provider port

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_unaware
   CMD_VAR   = has_c_port
   CMD_VAR   = has_s_port
   CMD_VAR   = has_s_custom_port

VARIABLE_BEGIN
   vlan_port_conf_t      vport_conf;
VARIABLE_END

CODE_BEGIN
    memset(&vport_conf, 0, sizeof(vport_conf));
    /* Populate Port Type */
    if (has_unaware) {
        vport_conf.port_type = VLAN_PORT_TYPE_UNAWARE;
    } else if (has_c_port) {
        vport_conf.port_type = VLAN_PORT_TYPE_C;
    } else if (has_s_port) {
#if defined(VTSS_FEATURE_VLAN_PORT_V2)
        vport_conf.port_type = VLAN_PORT_TYPE_S;
#endif
    } else if (has_s_custom_port) {
#if defined(VTSS_FEATURE_VLAN_PORT_V2)
        vport_conf.port_type = VLAN_PORT_TYPE_S_CUSTOM;
#endif
    }
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 0, 0, 1, 0);
CODE_END

NO_FORM_VARIABLE_BEGIN
   vlan_port_conf_t      vport_conf;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(has_unaware);
    VLAN_UNUSED_PARAM(has_c_port);
    VLAN_UNUSED_PARAM(has_s_port);
    VLAN_UNUSED_PARAM(has_s_custom_port);
    memset(&vport_conf, 0, sizeof(vport_conf));
    /* Default port type is unaware */
    vport_conf.port_type = VLAN_PORT_TYPE_UNAWARE;
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 0, 0, 1, 0);
NO_FORM_CODE_END
CMD_END

