CMD_BEGIN
COMMAND         = show interface <port_type_list> [switchport [access | trunk | hybrid] ]
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = Use the how interfaces command to display the administrative and operational status of all interfaces \
                  or a specified interface.
#DOC_CMD_DEFAULT =
DOC_CMD_USAGE   = Use this command to display the switch port characteristics of all interfaces on that switch in the stack.
DOC_CMD_EXAMPLE = This example shows viewing of output from the show interface command for an interface Gi1/0/1
DOC_CMD_EXAMPLE = Switch(config-if)#show interface gigabitEthernet 1/1 switchport
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_interfaces_show
PRIVILEGE = ICLI_PRIVILEGE_0
PROPERTY  = ICLI_CMD_PROP_GREP

CMD_MODE  = ICLI_CMD_MODE_EXEC

   HELP = Show running system information
   HELP = Interface status
   HELP = ports list
   HELP = Show interface switchport information
   HELP = Show access ports status
   HELP = Show trunk ports status
   HELP = Show hybrid ports status

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = in_port_list
   CMD_VAR   = has_switchport
   CMD_VAR   = has_access
   CMD_VAR   = has_trunk
   CMD_VAR   = has_hybrid

VARIABLE_BEGIN
    u32                         range_idx, cnt_idx;
    vtss_usid_t                 usid;
    vtss_port_no_t              uport;
    vtss_vid_t                  vid;
    i8                          buf[VLAN_BUF_SIZE], *vlan_buf;
    vlan_port_mode_conf_t       pconf;
    vlan_port_mode_t            mode = VLAN_PORT_MODE_ACCESS;
    BOOL                        enable;
    u8                          vlan_mask[VLAN_BIT_MASK_LEN];
    vlan_port_conf_t            port_conf;
VARIABLE_END

CODE_BEGIN
    if (has_switchport) {
        for (range_idx = 0; range_idx < in_port_list->cnt; range_idx++) {
            usid = in_port_list->switch_range[range_idx].usid;
            for (cnt_idx = 0; cnt_idx < in_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
                uport = in_port_list->switch_range[range_idx].begin_uport + cnt_idx;
                if (has_access) {
                    mode = VLAN_PORT_MODE_ACCESS;
                } else if (has_trunk) {
                    mode = VLAN_PORT_MODE_TRUNK;
                } else if (has_hybrid) {
                    mode = VLAN_PORT_MODE_HYBRID;
                }
                if ((vlan_mgmt_port_mode_get(topo_usid2isid(usid), uport2iport(uport), &pconf)) != VTSS_RC_OK) {
                    ICLI_PRINTF("Failure getting port information\n");
                    return FALSE;
                }
                if (has_access || has_trunk || has_hybrid) {
                    if (mode != pconf.mode) {
                        continue;
                    }
                }
                ICLI_PRINTF("Name: %s\n", icli_port_info_txt(usid, uport, buf));
                ICLI_PRINTF("Administrative mode: %s\n", vlan_port_mode_txt(pconf.mode));
                if ((vlan_mgmt_port_access_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid)) == VTSS_RC_OK) {
                    ICLI_PRINTF("Access Mode VLAN: %u\n", vid);
                } /* if ((vlan_mgmt_port_access_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid)) == VTSS_RC_OK) */
                if ((vlan_mgmt_port_native_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid, VLAN_PORT_MODE_TRUNK)) 
                    == VTSS_RC_OK) {
                    ICLI_PRINTF("Trunking Native Mode VLAN: %u\n", vid);
                } /* if ((vlan_mgmt_port_native_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid)) == VTSS_RC_OK) */
                if ((vlan_mgmt_native_vlan_tagging_get(topo_usid2isid(usid), uport2iport(uport), &enable)) == VTSS_RC_OK) {
                    ICLI_PRINTF("Administrative Native VLAN tagging: %s\n", (enable)? "enabled" : "disabled");
                } /* if ((vlan_mgmt_native_vlan_tagging_get(&enable)) == VTSS_RC_OK) */
                if ((vlan_buf = (i8 *)malloc(VLAN_LIST_BUF_SIZE)) == NULL) {
                    return FALSE;
                }
                if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vlan_mask, 
                    VLAN_PORT_MODE_TRUNK)) == VTSS_RC_OK) {
                    ICLI_PRINTF("Trunking VLANs Enabled: %s\n", vlan_bit_mask_to_txt(vlan_mask, vlan_buf));
                } /* if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vlan_mask)) == VTSS_RC_OK) */
                if ((vlan_mgmt_hybrid_port_conf_get(topo_usid2isid(usid), uport2iport(uport), &port_conf)) == VTSS_RC_OK) {
                    ICLI_PRINTF("Hybrid port configuration\n");
                    ICLI_PRINTF("-------------------------\n");
                    ICLI_PRINTF("Port Type: %s\n", vlan_port_type_txt(port_conf.port_type));
                    ICLI_PRINTF("Acceptable Frame Type: %s\n", vlan_frame_type_txt(port_conf.frame_type));
                    ICLI_PRINTF("Ingress filter: %s\n", ((port_conf.ingress_filter) ? "Enabled" : "Disabled"));
                    ICLI_PRINTF("Egress tagging: %s\n", vlan_static_tag_type_txt(port_conf.tx_tag_type));
                    if ((vlan_mgmt_port_native_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid, VLAN_PORT_MODE_HYBRID)) 
                         == VTSS_RC_OK) {
                        ICLI_PRINTF("Hybrid Native Mode VLAN: %u\n", vid);
                    } /* if ((vlan_mgmt_port_native_vlan_get(topo_usid2isid(usid), uport2iport(uport), &vid)) == VTSS_RC_OK) */
                    if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vlan_mask, 
                         VLAN_PORT_MODE_HYBRID)) == VTSS_RC_OK) {
                        ICLI_PRINTF("Hybrid VLANs Enabled: %s\n", vlan_bit_mask_to_txt(vlan_mask, vlan_buf));
                    } /* if ((vlan_mgmt_port_allowed_vlans_get(topo_usid2isid(usid), uport2iport(uport), vlan_mask)) == VTSS_RC_OK) */
                }
                ICLI_PRINTF("\n");
                free(vlan_buf);
            } /* for (cnt_idx = 0; cnt_idx < in_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
        } /* for (range_idx = 0; range_idx < in_port_list->cnt; range_idx++) */
    } /* if (has_switchport) */
CODE_END
CMD_END

CMD_BEGIN
COMMAND         = show vlan [id <vlan_list> | name <word32> | brief]
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = Use the show vlan command to view the VLAN configuration.
#DOC_CMD_DEFAULT =
DOC_CMD_USAGE   = To view the VLAN members by VLAN ID used id option. To view the VLAN members \
                  by name use the name option.
DOC_CMD_EXAMPLE = This example shows viewing of VLAN membership configuration by VLAN ID.
DOC_CMD_EXAMPLE = Switch(config-if)#show vlan id 2
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = vlan_show
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_EXEC

   HELP = Show running system information
   HELP = VLAN status
   HELP = VLAN status by VLAN id
   HELP = VLAN IDs 1-4095
   HELP = VLAN status by VLAN name
   HELP = A VLAN name
   HELP = VLAN summary information

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_id
   CMD_VAR   = v_vlan_list
   CMD_VAR   = has_name
   CMD_VAR   = v_name
   CMD_VAR   = has_brief

VARIABLE_BEGIN
    u32                         idx;
    BOOL                        first;
    vtss_vid_t                  vidx;
    vlan_mgmt_vlan_name_conf_t  conf;
VARIABLE_END

CODE_BEGIN
    VLAN_UNUSED_PARAM(has_brief); 
    if (!has_id && !has_name) {
        first = TRUE;
        for (vidx = VLAN_TAG_MIN_VALID ; vidx <= VLAN_TAG_MAX_VALID; vidx++) {
            vlan_conf_show(session_id, vidx, first);
            if (first) {
                first = FALSE;
            }
        }
    } else {
        if (has_id) {
            if (!v_vlan_list) {
                ICLI_PRINTF("%% Invalid operation.\n\n");
                return FALSE;
            }
            first = TRUE;
            for (idx = 0; idx < v_vlan_list->cnt; idx++) {
                for (vidx = v_vlan_list->range[idx].min; vidx <= (v_vlan_list->range[idx].max); vidx++) {
                    vlan_conf_show(session_id, vidx, first);
                    if (first) {
                        first = FALSE;
                    }
                }
            }
        }
        if (has_name) {
            if (v_name) {
                strcpy(conf.vlan_name, v_name);
            }
            conf.name_valid = TRUE;
            if (vlan_mgmt_vlan_name_get(0, &conf) == VTSS_RC_OK) {
                vlan_conf_show(session_id, conf.vid, TRUE);
            } else {
                ICLI_PRINTF("Entry with VLAN name %s not found\n", v_name);
            }
        } /* if (has_name) */
    }
CODE_END
CMD_END

CMD_BEGIN
COMMAND         = name <word32>
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = Use the name <word32> command to configure VLAN name.
DOC_CMD_DEFAULT = The no form of this command will delete the VLAN name to VLAN mapping.
DOC_CMD_USAGE   = You can enter up to 32 alphanumeric characters to name the VLAN. At least one alphabet must be present \
                  in a VLAN name
DOC_CMD_EXAMPLE = This example shows to configure VLAN name
DOC_CMD_EXAMPLE = Switch(config-if)#name vlan100
DOC_CMD_EXAMPLE = You can verify your settings by entering the show vlan privileged EXEC command.
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_name_set
PRIVILEGE = ICLI_PRIVILEGE_13

MODE_VAR = vlist

CMD_MODE  = ICLI_CMD_MODE_CONFIG_VLAN

   HELP = Ascii name of the VLAN
   HELP = The ascii name for the VLAN

   CMD_VAR   =
   CMD_VAR   = vname

VARIABLE_BEGIN
    vlan_mgmt_vlan_name_conf_t  conf;
    u32                         idx;
    vtss_vid_t                  vidx;
    vtss_rc                     rc;
VARIABLE_END

CODE_BEGIN
    if (vlist->cnt > 0) {
        if ((vlist->cnt > 1) || (((vlist->range[0].max) - (vlist->range[0].min)) > 1)) {
            ICLI_PRINTF("Can't modify name for multiple VLANs\n");
            return FALSE;
        }
    }
    for (idx = 0; idx < vlist->cnt; idx++) {
        for (vidx = vlist->range[idx].min; vidx <= vlist->range[idx].max; vidx++) {
            memset(&conf, 0, sizeof(conf));
            conf.vid = vidx;
            if (vname) {
                strcpy(conf.vlan_name, vname);
            }
            rc = vlan_mgmt_vlan_name_add(&conf, 0);
            if (rc == VLAN_ERROR_VLAN_NAME_PREVIOUSLY_CONFIGURED) {
                ICLI_PRINTF("Error: VLAN Name is already used for different VID\n");
            } else if(rc == VLAN_ERROR_VLAN_NAME_TABLE_FULL) {
                ICLI_PRINTF("Error: VLAN Name table Full. Only %d entries can be added\n", VLAN_NAME_MAX_CNT);
            }
        } /* for (vidx = vlist->range[idx].min; vidx <= vlist->range[idx].max; vidx++) */
    } /* for (idx = 0; idx < vlist->cnt; idx++) */
CODE_END

NO_FORM_VARIABLE_BEGIN
    u32                         idx;
    vtss_vid_t                  vidx;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    VLAN_UNUSED_PARAM(vname);
    for (idx = 0; idx < vlist->cnt; idx++) {
        for (vidx = vlist->range[idx].min; vidx <= vlist->range[idx].max; vidx++) {
            if ((vlan_mgmt_vlan_name_del_by_vid(vidx)) != VTSS_RC_OK) {
                ICLI_PRINTF("VLAN Name deletion failed.\n");
            } /* if ((vlan_mgmt_vlan_name_del_by_vid(vidx)) != VTSS_RC_OK) */
        } /* for (vidx = vlist->range[idx].min; vidx <= vlist->range[idx].max; vidx++) */
    } /* for (idx = 0; idx < vlist->cnt; idx++) */
NO_FORM_CODE_END
CMD_END
