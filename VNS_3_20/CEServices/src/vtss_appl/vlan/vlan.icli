#define VLAN_DEFAULT_TPID       0x88A8

static void vlan_icli_port_conf_set(vtss_isid_t isid, vtss_port_no_t port_no, vlan_port_conf_t *pconf, BOOL pvid, BOOL frametype, 
                                    BOOL ingressfilter, BOOL porttype, BOOL tx_tag)
{
    vlan_port_conf_t      conf;

    if ((vlan_mgmt_hybrid_port_conf_get(isid, port_no, &conf)) != VTSS_OK) {
        return;
    }
    conf.flags = VLAN_PORT_FLAGS_ALL;
    if (pvid) {
#ifdef VTSS_SW_OPTION_ACL
        if (mgmt_vlan_pvid_change(isid, port_no, pconf->pvid, conf.pvid) != VTSS_OK) {
            return;
        }
#endif /* VTSS_SW_OPTION_ACL */
        conf.pvid = pconf->pvid;
    }
    if (frametype) {
        conf.frame_type = pconf->frame_type;
    }
#ifdef VTSS_SW_OPTION_VLAN_INGRESS_FILTERING
    if (ingressfilter) {
        conf.ingress_filter = pconf->ingress_filter;
    }
#endif  /* VTSS_SW_OPTION_VLAN_INGRESS_FILTERING */
    if (tx_tag) {
        if (conf.tx_tag_type == VLAN_TX_TAG_TYPE_UNTAG_THIS) {
            conf.untagged_vid = conf.pvid;
        }
        conf.tx_tag_type = pconf->tx_tag_type;
    }
    if (porttype) {
        conf.port_type = pconf->port_type;
    }
    if((vlan_mgmt_hybrid_port_conf_set(isid, port_no, &conf)) != VTSS_OK) {
        return;
    }
}

static void vlan_cmd_vlan_port_conf(i32 session_id, vlan_port_conf_t *pconf,
                                    icli_stack_port_range_t *port_list_p, BOOL pvid, BOOL frametype, 
                                    BOOL ingressfilter, BOOL porttype, BOOL tx_tag)
{
    u32                   range_idx, cnt_idx;
    vtss_isid_t           usid;
    vtss_port_no_t        uport;

    for (range_idx = 0; range_idx < port_list_p->cnt; range_idx++) {
        usid = port_list_p->switch_range[range_idx].usid;
        for (cnt_idx = 0; cnt_idx < port_list_p->switch_range[range_idx].port_cnt; cnt_idx++) {
            uport = port_list_p->switch_range[range_idx].begin_uport + cnt_idx;
            vlan_icli_port_conf_set(topo_usid2isid(usid), uport2iport(uport), pconf, pvid, frametype, ingressfilter,
                                    porttype, tx_tag);
        } /* for (cnt_idx = 0; cnt_idx < port_list_p->switch_range[range_idx].port_cnt; cnt_idx++) */
    } /* for (range_idx = 0; range_idx < port_list_p->cnt; range_idx++) */
}

static char *vlan_frame_type_txt(vtss_vlan_frame_t tagged)
{               
    if (tagged == VTSS_VLAN_FRAME_ALL) {
        return "all";
    } else if (tagged == VTSS_VLAN_FRAME_TAGGED) {
        return "tagged";
#if defined(VTSS_FEATURE_VLAN_PORT_V2)
    } else if (tagged == VTSS_VLAN_FRAME_UNTAGGED) {
        return "untagged";
#endif      
    } else {
        return "unknown";
    }
}

static char *vlan_static_tag_type_txt(vlan_tx_tag_type_t tx_tag_type)
{
    if (tx_tag_type == VLAN_TX_TAG_TYPE_UNTAG_THIS) {
        return "all except-native"; 
    } else if (tx_tag_type == VLAN_TX_TAG_TYPE_UNTAG_ALL) {
        return "none";
    } else if (tx_tag_type == VLAN_TX_TAG_TYPE_TAG_ALL) {
        return "all";
    }
    return "";
}

static char *vlan_port_type_txt(vlan_port_type_t pt)
{
    if (pt == VLAN_PORT_TYPE_UNAWARE) {
        return "unaware";
    } else if (pt == VLAN_PORT_TYPE_C) {
        return "c-port";
#if defined(VTSS_FEATURE_VLAN_PORT_V2)
    } else if (pt == VLAN_PORT_TYPE_S) {
        return "s-port";
    } else if (pt == VLAN_PORT_TYPE_S_CUSTOM) {
        return "s-custom-port";
#endif
    } else {
        return "unknown-port";
    }
}


static char *vlan_port_mode_txt(vlan_port_mode_t mode)
{
    if (mode == VLAN_PORT_MODE_ACCESS) {
        return "access";
    } else if (mode == VLAN_PORT_MODE_TRUNK) {
        return "trunk";
    } else if (mode == VLAN_PORT_MODE_HYBRID) {
        return "hybrid";
    }
    return "";
}   

static void vlan_conf_show(i32 session_id, vtss_vid_t vid, BOOL first)
{
    switch_iter_t               sit;
    port_iter_t                 pit;
    vlan_mgmt_entry_t           conf;
    char                        str_buf[VLAN_BUF_SIZE], buf[VLAN_BUF_SIZE + 40], *p;
    u32                         port_cnt;
    BOOL                        first_port, first_line, eol;
    vlan_port_mode_conf_t       pconf;

    //ICLI_PRINTF("\n");
    (void)switch_iter_init(&sit, VTSS_ISID_GLOBAL, SWITCH_ITER_SORT_ORDER_USID);
    while (switch_iter_getnext(&sit)) {
        if (vlan_mgmt_vlan_get(sit.isid, vid, &conf, 0, VLAN_USER_STATIC, VLAN_MEMBERSHIP_OP) == VTSS_OK) {
            if (first) {
#ifdef  VTSS_SW_OPTION_VLAN_NAME
                ICLI_PRINTF("%-4s  %-32s  %s\n", "VLAN", "Name", "Ports");
                ICLI_PRINTF( "----------------------------------------------------------------------------------------------------\n");
#else
                ICLI_PRINTF("%-4s  %s\n", "VLAN", "Ports");
                ICLI_PRINTF( "----------------------------------------------------------------------------------------------------\n");
#endif
                first = FALSE;
            }
#ifdef  VTSS_SW_OPTION_VLAN_NAME
            ICLI_PRINTF("%-4d  %-32s  ", vid, conf.vlan_name);
#else
            ICLI_PRINTF("%-4d  ", vid);
#endif
             port_cnt = 0;
             p = &buf[0];
             first_port = TRUE;
             first_line = TRUE;
             eol = FALSE;
            (void) port_iter_init(&pit, NULL, sit.isid, PORT_ITER_SORT_ORDER_UPORT, PORT_ITER_FLAGS_NORMAL);
            while (port_iter_getnext(&pit)) {
                (void)vlan_mgmt_port_mode_get(sit.isid, pit.iport, &pconf);
                if (conf.ports[pit.iport] && (pconf.mode == VLAN_PORT_MODE_ACCESS)) {
                    port_cnt++;
                    (void)icli_port_info_txt(sit.usid, pit.uport, str_buf);
                    if (first_port == FALSE) {
                        if (eol == TRUE) {
                            ICLI_PRINTF(",\n");
                            eol = FALSE;
                        } else {
                            p += sprintf(p, ",");
                        }
                    }
                    p += sprintf(p, "%s", str_buf);
                    first_port = FALSE;
                    if ((port_cnt % 3) == 0) {
                        if (first_line == TRUE) {
                            ICLI_PRINTF("%s", buf);
                            first_line = FALSE;
                        } else {
                            ICLI_PRINTF("%-38s  %s", "", buf);
                        }
                        eol = TRUE;
                        p = &buf[0];
                    }
                }
            } /* while (port_iter_getnext(&pit)) */
            if (port_cnt % 3) {
                if (port_cnt > 3) {
                    ICLI_PRINTF("%-38s  %s\n", "", buf);
                } else {
                    ICLI_PRINTF("%s\n", buf);
                }
            }
            ICLI_PRINTF("\n");
        } /* if (vlan_mgmt_vlan_get(sit.isid, vid, &conf, 0, VLAN_USER_STATIC, VLAN_MEMBERSHIP_OP) == VTSS_OK) */
    } /* while (switch_iter_getnext(&sit)) */
}
FUNCTION_END

