    memset(&vport_conf, 0, sizeof(vport_conf));
    /* Populate Port Type */
    if (has_all) {
        vport_conf.frame_type = VTSS_VLAN_FRAME_ALL;
    } else if (has_tagged) {
        vport_conf.frame_type = VTSS_VLAN_FRAME_TAGGED;
    } else if (has_untagged) {
    #if defined(VTSS_FEATURE_VLAN_PORT_V2)
        vport_conf.frame_type = VTSS_VLAN_FRAME_UNTAGGED;
    #else
        ICLI_PRINTF("This is not supported on this chip\n");
        return FALSE;
    #endif
    }
    vlan_cmd_vlan_port_conf(session_id, &vport_conf, mode_port_list, 0, 1, 0, 0, 0);
CODE_END

NO_FORM_VARIABLE_BEGIN
   vlan_port_conf_t      vport_conf;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
