CMD_BEGIN
COMMAND         = switchport mode {access | trunk | hybrid}
# /* ------------------------------------------------------------------------------------------------------------------------
DOC_CMD_DESC    = Use the switchport mode command to define the type of the port.
DOC_CMD_DEFAULT = Use the no form of this command to return to the default mode that is access mode.
DOC_CMD_USAGE   = To configure a switch port as access port select the mode to access else to trunk or hybrid.
DOC_CMD_EXAMPLE = This example shows to configure a switch port as trunk port. 
DOC_CMD_EXAMPLE = Switch(config-if)#switchport mode trunk
DOC_CMD_EXAMPLE = You can verify your settings by entering the show vlan privileged EXEC command.
# --------------------------------------------------------------------------------------------------------------------------*/

FUNC_NAME = icli_vlan_port_mode_set
PRIVILEGE = ICLI_PRIVILEGE_13

CMD_MODE  = ICLI_CMD_MODE_INTERFACE_PORT_LIST

MODE_VAR  = mode_port_list

   HELP = Set switching mode characteristics
   HELP = Set trunking mode of the interface
   HELP = Set trunking mode to ACCESS unconditionally
   HELP = Set trunking mode to TRUNK unconditionally
   HELP = Set trunking mode to HYBRID unconditionally

   CMD_VAR   =
   CMD_VAR   =
   CMD_VAR   = has_access
   CMD_VAR   = has_trunk
   CMD_VAR   = has_hybrid

VARIABLE_BEGIN
   vlan_port_mode_conf_t pmode, pconf;
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
VARIABLE_END

CODE_BEGIN
    if (has_access || has_trunk || has_hybrid) {
        for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
            usid = mode_port_list->switch_range[range_idx].usid;
            for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
                uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
                if (has_access) {
                    pmode.mode = VLAN_PORT_MODE_ACCESS;
                } else if (has_trunk) {
                    pmode.mode = VLAN_PORT_MODE_TRUNK;
                } else {
                    pmode.mode = VLAN_PORT_MODE_HYBRID;
                }
                if ((vlan_mgmt_port_mode_get(topo_usid2isid(usid), uport2iport(uport), &pconf)) == VTSS_RC_OK) {
                    if (pconf.mode != pmode.mode) {
                        if ((vlan_mgmt_port_mode_set(topo_usid2isid(usid), uport2iport(uport), &pmode)) != VTSS_RC_OK) {
                            T_D("vlan_mgmt_port_mode_set failed");
                        } /* if ((vlan_mgmt_port_mode_set(topo_usid2isid(usid), uport2iport(uport), &pmode)) != VTSS_RC_OK) */
                    } /* if (pconf.mode != pmode.mode) */
                } /* if ((vlan_mgmt_port_mode_get(topo_usid2isid(usid), uport2iport(uport), &pconf)) == VTSS_RC_OK) */
            } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
        } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
    } /* if (has_access || has_trunk) */
CODE_END

NO_FORM_VARIABLE_BEGIN
   vlan_port_mode_conf_t pmode, pconf;
   u32                   range_idx, cnt_idx;
   vtss_isid_t           usid;
   vtss_port_no_t        uport;
NO_FORM_VARIABLE_END

NO_FORM_CODE_BEGIN
    if (has_access || has_trunk || has_hybrid) {
        for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) {
            usid = mode_port_list->switch_range[range_idx].usid;
            for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) {
                uport = mode_port_list->switch_range[range_idx].begin_uport + cnt_idx;
                pmode.mode = VLAN_PORT_MODE_ACCESS;
                if ((vlan_mgmt_port_mode_get(topo_usid2isid(usid), uport2iport(uport), &pconf)) == VTSS_RC_OK) {
                    if (pconf.mode != pmode.mode) {
                        if ((vlan_mgmt_port_mode_set(topo_usid2isid(usid), uport2iport(uport), &pmode)) != VTSS_RC_OK) {
                            T_D("vlan_mgmt_port_mode_set failed");
                        } /* if ((vlan_mgmt_port_mode_set(topo_usid2isid(usid), uport2iport(uport), &pmode)) != VTSS_RC_OK) */
                    } /* if (pconf.mode != pmode.mode) */
                } /* if ((vlan_mgmt_port_mode_get(topo_usid2isid(usid), uport2iport(uport), &pconf)) == VTSS_RC_OK) */
            } /* for (cnt_idx = 0; cnt_idx < mode_port_list->switch_range[range_idx].port_cnt; cnt_idx++) */
        } /* for (range_idx = 0; range_idx < mode_port_list->cnt; range_idx++) */
    } /* if (has_access || has_trunk) */
NO_FORM_CODE_END

CMD_END

