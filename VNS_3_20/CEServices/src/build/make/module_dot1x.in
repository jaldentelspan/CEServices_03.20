DIR_nas          := $(DIR_APPL)/nas
DIR_nas_base     := $(DIR_nas)/base
DIR_nas_platform := $(DIR_nas)/platform

# For further NAS options, please refer to module_nas_options.in.

# Our object files - prefixed to avoid filename clash
OBJECTS_nas_base       := $(addprefix nas_base_, nas.o)
OBJECTS_nas_dot1x      := $(addprefix nas_dot1x_, auth.o auth_sm.o)
OBJECTS_nas_platform   := dot1x.o    \
  $(call if-module,vcli,dot1x_cli.o) \
  $(call if-module,web,dot1x_web.o)  \
  $(call if-module,conf_xml,dot1x_xml.o)

OBJECTS_dot1x := $(OBJECTS_nas_platform) $(OBJECTS_nas_base) $(OBJECTS_nas_dot1x)

# Needed due to prefixing
$(OBJECTS_nas_base): nas_base_%.o: $(DIR_nas_base)/common/%.c
	$(call compile_c, $@, $<, -D__ECOS)

$(OBJECTS_nas_dot1x): nas_dot1x_%.o: $(DIR_nas_base)/auth/%.c
	$(call compile_c, $@, $<, -D__ECOS)

$(OBJECTS_nas_platform): %.o: $(DIR_nas_platform)/%.c
	$(call compile_c, $@, $<)

# Web Content Generation
WEB_CONTENT += $(DIR_nas_platform)/html

LINT_FILES_dot1x += $(DIR_nas_platform)/dot1x.c $(DIR_nas_platform)/dot1x_cli.c $(DIR_nas_base)/common/nas.c $(DIR_nas_base)/auth/auth.c $(DIR_nas_base)/auth/auth_sm.c $(DIR_nas_platform)/dot1x_web.c

# Include files
INCLUDES += -I$(DIR_nas_base)/include -I$(DIR_nas_platform)

# Tidy files
TIDY_FILES_dot1x += $(DIR_nas_platform)/html/*.htm $(DIR_nas_platform)/html/help/*.htm

# JSlint files
JSLINT_FILES_dot1x += $(TIDY_FILES_dot1x)

# Code-style check - two spaces
# Not all files pass code-style check, mainly because of <SPACES> in :"#ifdef X\n<SPACES>#include xxx\n#endif"
#VTSS_CODE_STYLE_CHK_FILES_TWO_INDENT_dot1x := $(LINT_FILES_dot1x)
VTSS_CODE_STYLE_CHK_FILES_TWO_INDENT_dot1x := $(DIR_nas_platform)/dot1x_cli.c $(DIR_nas_base)/auth/auth.c

# Code-style check - four spaces
VTSS_CODE_STYLE_CHK_FILES_dot1x := $(DIR_nas_base)/auth/auth_sm.c

