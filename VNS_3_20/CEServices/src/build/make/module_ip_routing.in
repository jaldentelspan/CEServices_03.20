DIR_ip_routing := $(DIR_APPL)/ip_routing

OBJECTS_ip_routing := ip_routing.o            \
  ip_routing_os_ecos.o                        \
  $(call if-module,vcli,ip_routing_cli.o)     \
  $(call if-module,web,ip_routing_web.o)      \
  $(call if-module,conf_xml,ip_routing_xml.o)

$(OBJECTS_ip_routing): %.o: $(DIR_ip_routing)/%.c
	$(call compile_c, $@, $<)

# Include files
INCLUDES += -I$(DIR_ip_routing)

# Web Content Generation
WEB_CONTENT += $(DIR_ip_routing)/html

# Files to be linted
# LPOVLSENTBD: Not lintable.
# LINT_FILES_ip_routing += $(addprefix $(DIR_ip_routing)/,$(OBJECTS_ip_routing:.o=.c))

# Code style files
VTSS_CODE_STYLE_CHK_FILES_ip_routing += $(DIR_ip_routing)/*.*

# Tidy files
TIDY_FILES_ip_routing += $(DIR_ip_routing)/html/*.htm $(DIR_ip_routing)/html/help/*.htm

# JSlint files
JSLINT_FILES_ip_routing += $(TIDY_FILES_ip_routing)

